  - m_Id: 18106501585932288
    m_Localized: "\uC774 \uAC8C\uC784\uC740 VTuber\uADF8\uB8F9 Hololive\uC758 2\uCC28
      \uCC3D\uC791\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 18106501585932289
    m_Localized: "\uB09C\uC774\uB3C4 \uC120\uD0DD"
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126592
    m_Localized: "\uC774\uC81C \uB9C9 \uAC8C\uC784\uC744 \uC2DC\uC791\uD55C \uBD84\uB4E4\uC5D0\uAC8C
      \uC801\uD569\uD55C \uB09C\uC774\uB3C4\uC785\uB2C8\uB2E4. \uCD5C\uC885\uBCF4\uC2A4
      '\uB77C\uD50C\uB77C\uC2A4 \uB2E4\uD06C\uB2C8\uC2A4'\uAC00 \uB4F1\uC7A5\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126593
    m_Localized: "\uBB34\uB09C\uD55C \uD50C\uB808\uC774\uB97C \uC704\uD55C \uAC00\uC7A5
      \uC77C\uBC18\uC801\uC778 \uB09C\uC774\uB3C4\uC785\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126594
    m_Localized: "NORMAL \uBAA8\uB4DC \uB300\uBE44 \uBAAC\uC2A4\uD130\uB4E4\uC774
      50% \uB354 \uAC15\uD574\uC9D1\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126595
    m_Localized: "BGM \uC124\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126596
    m_Localized: "SFX \uC124\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126597
    m_Localized: "\uD654\uBA74 \uBC30\uC728 \uC124\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126598
    m_Localized: "\uD004\uB9AC\uD2F0 \uC124\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126599
    m_Localized: "\uC5B8\uC5B4 \uC124\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126600
    m_Localized: "\uC774 \uAC8C\uC784\uC740 \uBC84\uD29C\uBC84 \uADF8\uB8F9 'Hololive'\uC758
      2\uCC28 \uCC3D\uC791 \uAC8C\uC784\uC785\uB2C8\uB2E4.\n\n\nTeam JEONGWON\n\n 
      \uAD6C\uC131\uC6D0 -\n\n        game design, art by runinzem\n\n        rogrammed
      by a2no\n\n\n\uB3C4\uC6C0\uC744 \uC8FC\uC2E0 \uBD84\uB4E4 -\n\n  \uD50C\uB808\uC774\uD14C\uC2A4\uD130\n\n        
      Ali Play\n\n\n  SFX \uC81C\uACF5\n\n\n        pixabay        ViRiX               
      artisticdude\n\n        Skorpio        \u68EE\u7530\u4EA4\u4E00        faxcorp\n\n       
      jwiese        qubodup        dklon        \n\n        \n  BGM \uC81C\uACF5\n\n\n        
      (FIELD1)\n         \u30D5\u30A1\u30F3\u30BF\u30B8\u30FC03(\u6226\u3044\u306E\u30A2\u30FC\u30C1)
      - \u68EE\u7530\u4EA4\u4E00\n\n         (FIELD2)\n         \u30D5\u30A1\u30F3\u30BF\u30B8\u30FC04(\u6226\u6144\u306E\u65CB\u5F8B)
      - \u68EE\u7530\u4EA4\u4E00\n\n         (FIELD3)\n         \u30D5\u30A1\u30F3\u30BF\u30B8\u30FC05(Peaceful
      Place) - \u68EE\u7530\u4EA4\u4E00\n\n         (BOSS)\n         \u30D5\u30A1\u30F3\u30BF\u30B8\u30FC15(\u99C6\u3051\u629C\u3051\u308B\u6226\u5834\u306E\u5D50)
      - \u68EE\u7530\u4EA4\u4E00\n\n         (BOSSRAID)\n         \u30D5\u30A1\u30F3\u30BF\u30B8\u30FC11(bravery
      heart) - \u68EE\u7530\u4EA4\u4E00\n\n         (MAIN)\n          Lady of the
      80's - Grand_Project"
    m_Metadata:
      m_Items: []
