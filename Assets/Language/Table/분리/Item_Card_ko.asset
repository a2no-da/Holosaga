  m_SharedData: {fileID: 11400000, guid: 9468c17b4d71ffb4c91a88932a469897, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 126418915328
    m_Localized: "POWER \uCE74\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 126465052672
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uB4E4\uC758 POWER\uAC00 5% \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126465052673
    m_Localized: "\uACF5\uACA9\uC18D\uB3C4 \uCE74\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 126465052674
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uB4E4\uC758 \uACF5\uACA9\uC18D\uB3C4\uAC00
      4% \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246976
    m_Localized: "HP \uCE74\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246977
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uB4E4\uC758 HP\uAC00 30 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246978
    m_Localized: "\uCFE8\uD0C0\uC784 \uAC10\uC18C \uCE74\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246979
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uB4E4\uC758 \uD328\uC2DC\uBE0C, \uC561\uD2F0\uBE0C
      \uD328\uD134\uC758 \uCFE8\uD0C0\uC784\uC774 5% \uAC10\uC18C\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246980
    m_Localized: "\uC6D0\uB9E8\uC1FC"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246981
    m_Localized: "\uC720\uB2DB\uC774 1\uBA85\uBC16\uC5D0 \uC5C6\uB2E4\uBA74, \uD574\uB2F9
      \uC720\uB2DB\uC740 POWER\uAC00 100%, \uACF5\uACA9\uC18D\uB3C4\uAC00 40% \uC99D\uAC00\uD568\uACFC
      \uB3D9\uC2DC\uC5D0 HP\uAC00 50% \uAC10\uC18C\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246982
    m_Localized: "\uAC70\uC778\uD654"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246983
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uB4E4\uC758 \uCCB4\uB825\uC774 20% \uC99D\uAC00\uD569\uB2C8\uB2E4.
      \uC720\uB2DB\uB4E4\uC758 \uD06C\uAE30\uAC00 20% \uCEE4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246984
    m_Localized: "\uB048\uB048\uC774"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246985
    m_Localized: "\uC804\uBC29 \uC138\uB85C 2 \uB77C\uC778\uC5D0 \uB048\uB048\uC774\uB97C
      \uC124\uCE58\uD569\uB2C8\uB2E4. \uB048\uB048\uC774\uB294 \uBAAC\uC2A4\uD130\uB97C
      60% \uB290\uB824\uC9C0\uAC8C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246986
    m_Localized: "\uC790\uB9AC\uC0AC\uC218"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246987
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uC758 POWER\uAC00 70%, HP\uAC00 20%,
      \uACF5\uACA9\uC18D\uB3C4\uAC00 30% \uC99D\uAC00\uD558\uB294 \uB300\uC2E0, breakStage\uB97C
      \uC81C\uC678\uD55C \uBAA8\uB4E0 \uB77C\uC6B4\uB4DC\uC5D0\uC11C \uC2A4\uC704\uCE6D\uC744
      \uC0AC\uC6A9\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 126469246988
    m_Localized: "\uC2A4\uD2B8\uB808\uCE6D"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246989
    m_Localized: "\uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uB4E4\uC758 \uBC94\uC704\uAC00
      2\uCE78 \uC99D\uAC00\uD558\uACE0, \uACF5\uACA9\uC18D\uB3C4\uAC00 20% \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246990
    m_Localized: "\uCD5C\uACE0\uC758 \uD30C\uD2B8\uB108"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246991
    m_Localized: "1\uBC88 \uC720\uB2DB\uACFC 2\uBC88 \uC720\uB2DB\uC774 \uC11C\uB85C
      3x3\uB9CC\uD07C\uC758 \uBC94\uC704\uB97C \uC0DD\uC131\uD569\uB2C8\uB2E4. \uC774
      \uBC94\uC704\uAC00 \uC11C\uB85C \uACB9\uCCD0\uC788\uB2E4\uBA74, \uC11C\uB85C\uC758
      POWER\uB97C 30%, \uACF5\uACA9\uC18D\uB3C4\uB97C 30% \uC99D\uAC00\uC2DC\uD0B4\uACFC
      \uB3D9\uC2DC\uC5D0 \uBC94\uC704\uC548\uC5D0 \uC788\uB294 \uBAAC\uC2A4\uD130\uB4E4\uC744
      50% \uB290\uB9AC\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246992
    m_Localized: "\uBC84\uD168!"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246993
    m_Localized: "\uD544\uB4DC\uC5D0 \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC774
      \uC874\uC7AC\uD55C\uB2E4\uBA74, \uBAA8\uB4E0 \uC720\uB2DB\uC758 HP \uC7AC\uC0DD\uB825(\uCD08
      \uB2F9 \uC720\uB2DB\uC774 \uC790\uCCB4\uC801\uC73C\uB85C \uD68C\uBCF5\uD558\uB294
      HP\uB7C9)\uC774 6 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246994
    m_Localized: "\uC575\uCF5C"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246995
    m_Localized: "\uD544\uB4DC\uC5D0 \uC11C\uD3EC\uD130 \uC720\uB2DB\uC774 \uC874\uC7AC\uD55C\uB2E4\uBA74,
      \uBAA8\uB4E0 \uC720\uB2DB\uC774 \uBD80\uD65C \uB2A5\uB825\uC744 \uC5BB\uC2B5\uB2C8\uB2E4.
      \uBD80\uD65C\uD55C \uC720\uB2DB\uC740 5\uCD08\uAC04 \uACF5\uACA9\uC18D\uB3C4\uAC00
      50% \uC99D\uAC00\uD558\uB294 \uBC84\uD504\uB97C \uC5BB\uC2B5\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784
      70\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246996
    m_Localized: "\uC8FC\uC2A4 \uD30C\uD2F0"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246997
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uB4E4\uC5D0\uAC8C '\uAE30\uBCF8 \uD328\uD134
      \uC2DC\uC804 \uC2DC 30% \uD655\uB960\uB85C \uB79C\uB364\uD55C \uD0C0\uC77C\uC5D0
      \uB3C5\uBCD1\uC744 \uB358\uC9D0' \uD6A8\uACFC\uB97C \uBD80\uC5EC\uD569\uB2C8\uB2E4.
      \uB3C5\uBCD1\uC740 \uB5A8\uC5B4\uC9C4 \uD0C0\uC77C \uBC94\uC704\uC5D0 90\uC758
      \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469246998
    m_Localized: "\uD0C4\uCC3D \uBCF4\uAE09"
    m_Metadata:
      m_Items: []
  - m_Id: 126469246999
    m_Localized: "\uD22C\uC0AC\uCCB4 \uC720\uB2DB\uB4E4\uC5D0\uAC8C '\uAE30\uBCF8
      \uD328\uD134 \uC2DC\uC804 \uC2DC \uC790\uC2E0\uC758 \uD30C\uC6CC\uC5D0 \uBE44\uB840\uD558\uC5EC
      \uD53C\uD574\uB97C \uC785\uD788\uB294 \uB9C8\uBC95 \uD0C4\uC54C\uC744 2\uBC1C
      \uBC1C\uC0AC\uD568' \uD6A8\uACFC\uB97C \uBD80\uC5EC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469247000
    m_Localized: "\uC624\uBC84\uD074\uB7ED"
    m_Metadata:
      m_Items: []
  - m_Id: 126469247001
    m_Localized: "\uC561\uD2F0\uBE0C \uD328\uD134\uC744 \uC0AC\uC6A9\uD560 \uB54C
      \uB9C8\uB2E4, \uBAA8\uB4E0 \uC720\uB2DB\uC774 '\uD68C\uC624\uB9AC \uBC14\uB78C
      \uD22C\uC0AC\uCCB4'\uB97C \uB0A0\uB9BD\uB2C8\uB2E4. \uD22C\uC0AC\uCCB4\uB294
      50\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4. \uB354\uBD88\uC5B4, \uAC01
      \uC561\uD2F0\uBE0C \uD328\uD134\uC774 \uC0AC\uC6A9\uB420 \uB54C \uB9C8\uB2E4
      \uCFE8\uD0C0\uC784\uC774 1% \uAC10\uC18C\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 126469247002
    m_Localized: "\uBB35\uC9C1\uD55C \uACF5\uACA9"
    m_Metadata:
      m_Items: []
  - m_Id: 126469247003
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uC758 POWER\uAC00 50% \uC99D\uAC00\uD558\uB294
      \uB300\uC2E0 \uACF5\uACA9\uC18D\uB3C4\uAC00 20% \uAC10\uC18C\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1785497846779904
    m_Localized: "\uC870\uAC74\uC744 \uB9CC\uC871\uD558\uC9C0 \uBABB\uD574 \uC120\uD0DD\uD574\uB3C4
      \uD6A8\uACFC\uB97C \uBC1B\uC744 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 36397880783114240
    m_Localized: "\uC6D0\uD558\uB294 \uC5B4\uBE4C\uB9AC\uD2F0 \uCE74\uB4DC\uB97C
      \uC120\uD0DD\uD574\uC8FC\uC138\uC694. \uBCF4\uC2A4 \uC2A4\uD14C\uC774\uC9C0
      1, \uBCF4\uC2A4 \uC2A4\uD14C\uC774\uC9C0 5\uC5D0\uC11C \uCD1D 2\uBC88 \uACE0\uB97C
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
