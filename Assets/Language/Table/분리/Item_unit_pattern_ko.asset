  - m_Id: 99084636162
    m_Localized: "\uAE30\uBCF8 \uD328\uD134"
    m_Metadata:
      m_Items: []
  - m_Id: 99088830464
    m_Localized: "\uD328\uC2DC\uBE0C \uD328\uD134"
    m_Metadata:
      m_Items: []
  - m_Id: 99088830465
    m_Localized: "\uC561\uD2F0\uBE0C \uD328\uD134"
    m_Metadata:
      m_Items: []
  - m_Id: 8043184492544
    m_Localized: "\uBA38\uC2A4\uD0B7 \uBC1C\uC0AC"
    m_Metadata:
      m_Items: []
  - m_Id: 8043243212800
    m_Localized: "\uB9C8\uB9B0\uC774 \uC804\uBC29\uC73C\uB85C \uCD1D\uC54C\uC744
      1\uBC1C \uBC1C\uC0AC\uD569\uB2C8\uB2E4. \uCD1D\uC54C\uC740 100%\uC758 \uD53C\uD574\uB97C
      \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043243212801
    m_Localized: "\uBA38\uC2A4\uD0B7 3\uC5F0\uBC1C"
    m_Metadata:
      m_Items: []
  - m_Id: 8043243212802
    m_Localized: "\uB9C8\uB9B0\uC774 \uC804\uBC29\uC73C\uB85C \uCD1D\uC54C\uC744
      3\uBC1C \uBC1C\uC0AC\uD569\uB2C8\uB2E4. \uCD1D\uC54C\uC740 60%\uC758 \uD53C\uD574\uB97C
      \uC785\uD799\uB2C8\uB2E4. \uC774 \uD328\uD134\uC740 \uAE30\uBCF8 \uD328\uD134\uC744
      \uB300\uCCB4\uD558\uC5EC \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043243212803
    m_Localized: "\uBA38\uC2A4\uD0B7 5\uC5F0\uBC1C"
    m_Metadata:
      m_Items: []
  - m_Id: 8043243212804
    m_Localized: "\uB9C8\uB9B0\uC774 \uC804\uBC29\uC73C\uB85C \uCD1D\uC54C\uC744
      5\uBC1C \uBC1C\uC0AC\uD569\uB2C8\uB2E4. \uCD1D\uC54C\uC740 50%\uC758 \uD53C\uD574\uB97C
      \uC785\uD799\uB2C8\uB2E4. \uC774 \uD328\uD134\uC740 \uAE30\uBCF8 \uD328\uD134\uC744
      \uB300\uCCB4\uD558\uC5EC \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043243212805
    m_Localized: "\uB2F9\uADFC \uB358\uC9C0\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 8043243212806
    m_Localized: "\uD398\uCF54\uB77C\uAC00 \uD53C\uD574\uB97C \uC785\uC740 \uC720\uB2DB\uC5D0\uAC8C
      \uB2F9\uADFC\uC744 \uB358\uC838 HP\uB97C \uD68C\uBCF5\uC2DC\uD0B5\uB2C8\uB2E4
      (\uD68C\uBCF5\uB7C9 : \uD398\uCF54\uB77C\uC758 POWER 100%)."
    m_Metadata:
      m_Items: []
  - m_Id: 8043243212807
    m_Localized: "\uC0C8\uB85C\uC6B4 \uBA39\uAC70\uB9AC \uCD94\uAC00!"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407104
    m_Localized: "\uD398\uCF54\uB77C\uAC00 \uB2F9\uADFC\uC5D0 \uB354\uD574 \uC0C8\uB85C\uC6B4
      \uBA39\uAC70\uB9AC 2\uC885\uC744 \uCD94\uAC00\uD569\uB2C8\uB2E4.\n- \uC544\uBAAC\uB4DC
      : \uB2F9\uADFC\uC758 \uD68C\uBCF5\uD6A8\uACFC\uC5D0 \uB354\uD574 \uC720\uB2DB\uC758
      POWER\uB97C 4\uCD08\uAC04 30% \uC62C\uB824\uC90D\uB2C8\uB2E4.\n- \uC2DD\uC740\uCE58\uD0A8
      : \uB2F9\uADFC\uC758 \uD68C\uBCF5\uD6A8\uACFC\uC5D0 \uB354\uD574 \uC720\uB2DB\uC758
      \uACF5\uACA9\uC18D\uB3C4\uB97C 4\uCD08\uAC04 30% \uC62C\uB824\uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407105
    m_Localized: "\uBE45\uB2F9\uADFC \uD3ED\uBC1C"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407106
    m_Localized: "\uD398\uCF54\uB77C\uAC00 \uAC00\uC7A5 \uC55E\uC5D0 \uC788\uB294
      \uC720\uB2DB\uC5D0\uAC8C \uBE45\uB2F9\uADFC \uD3ED\uBC1C\uC744 \uC2DC\uC804\uD569\uB2C8\uB2E4.
      \uBE45\uB2F9\uADFC \uD3ED\uBC1C\uC740 \uBC94\uC704 \uB0B4\uC758 \uBAAC\uC2A4\uD130\uC5D0\uAC8C\uB294
      400%\uC758 \uD53C\uD574\uB97C \uC785\uD788\uB294 \uD55C\uD3B8, \uBAA8\uB4E0
      \uC720\uB2DB\uC758 POWER\uB97C 40%, \uACF5\uACA9\uC18D\uB3C4\uB97C 40%, \uCD5C\uB300
      \uCCB4\uB825\uC744 40%\uB9CC\uD07C 7\uCD08\uAC04 \uC62C\uB9BD\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784
      30\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407107
    m_Localized: "\uD654\uC5FC\uAD6C \uBC1C\uC0AC"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407108
    m_Localized: "\uD6C4\uB808\uC544\uAC00 \uC804\uBC29\uC73C\uB85C \uD654\uC5FC\uAD6C\uB97C
      1\uBC1C \uBC1C\uC0AC\uD569\uB2C8\uB2E4. \uD654\uC5FC\uAD6C\uB294 100%\uC758
      \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407109
    m_Localized: "\uD5EC\uD30C\uC774\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407110
    m_Localized: "4\uBC88\uC9F8 \uACF5\uACA9\uB9C8\uB2E4, \uD6C4\uB808\uC544\uAC00
      \uCCB4\uB825\uC774 \uAC00\uC7A5 \uB9CE\uC740 \uC801\uC5D0\uAC8C \uD5EC\uD30C\uC774\uC5B4\uB97C
      \uC2DC\uC804\uD569\uB2C8\uB2E4. \uD5EC\uD30C\uC774\uC5B4\uB294 \uBC94\uC704
      \uB0B4\uC758 \uBAAC\uC2A4\uD130\uC5D0\uAC8C 250%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407111
    m_Localized: "\uD30C\uC774\uC5B4\uBE0C\uB808\uC2A4"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407112
    m_Localized: "\uD6C4\uB808\uC544\uAC00 \uC804\uBC29\uC5D0 \uD30C\uC774\uC5B4\uBE0C\uB808\uC2A4\uB97C
      \uC2DC\uC804\uD558\uC5EC \uBC94\uC704 \uB0B4\uC758 \uBAAC\uC2A4\uD130\uC5D0\uAC8C
      20\uBC88\uC5D0 \uAC78\uCCD0 600%\uC758 \uD53C\uD574\uB97C \uB098\uB204\uC5B4
      \uC785\uD799\uB2C8\uB2E4. \uD30C\uC774\uC5B4\uBE0C\uB808\uC2A4\uAC00 \uC801\uC911\uD560
      \uB54C \uB9C8\uB2E4, \uD5EC\uD30C\uC774\uC5B4\uAC00 5%\uC758 \uD655\uB960\uB85C
      \uC790\uB3D9 \uC2DC\uC804\uB429\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784 18\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407113
    m_Localized: "\uBA54\uC774\uC2A4 \uC5B4\uD0DD"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407114
    m_Localized: "\uB178\uC5D8\uC774 \uBA54\uC774\uC2A4\uB97C \uD718\uB458\uB7EC
      100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407115
    m_Localized: "\uBB34\uC9C0\uB9C9\uC9C0\uD55C \uD798"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407116
    m_Localized: "4\uBC88\uC9F8 \uACF5\uACA9\uB9C8\uB2E4, \uB178\uC5D8\uC774 \uBA54\uC774\uC2A4\uB97C
      3\uBC88 \uD718\uB458\uB7EC 360%\uC758 \uD53C\uD574\uB97C \uB098\uB204\uC5B4
      \uC785\uD799\uB2C8\uB2E4. \uB9C8\uC9C0\uB9C9 \uACF5\uACA9\uC740 \uBAAC\uC2A4\uD130\uB97C
      2\uCD08\uAC04 \uACBD\uC9C1\uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407117
    m_Localized: "\uAE30\uC0AC\uC758 \uC0E4\uC6B0\uD305"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407118
    m_Localized: "\uB178\uC5D8\uC774 \uC6B0\uB801\uCC2C \uD568\uC131\uC744 \uB0B4\uC9C8\uB7EC
      \uBC94\uC704 \uB0B4\uC5D0 \uC788\uB294 \uBAAC\uC2A4\uD130\uB4E4\uC5D0\uAC8C
      150%\uC758 \uD53C\uD574\uB97C \uC785\uD788\uACE0 \uB178\uC5D8 \uC55E\uC73C\uB85C
      \uB04C\uC5B4\uC635\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784 8\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407119
    m_Localized: "\uC0BC\uC9C0\uCC3D \uCC0C\uB974\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407120
    m_Localized: "\uAD6C\uB77C\uAC00 \uC0BC\uC9C0\uCC3D\uC73C\uB85C \uBAAC\uC2A4\uD130\uB97C
      \uCC14\uB7EC 100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407121
    m_Localized: "\uBC14\uB2E4 \uD3ED\uBC1C"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407122
    m_Localized: "2\uBC88\uC9F8 \uACF5\uACA9\uB9C8\uB2E4, \uAD6C\uB77C\uAC00 \uBC14\uB2E4
      \uD3ED\uBC1C\uC744 \uC77C\uC73C\uCF1C \uBC94\uC704 \uB0B4\uC758 \uBAAC\uC2A4\uD130\uB4E4\uC5D0\uAC8C
      100%\uC758 \uD53C\uD574\uB97C \uCD94\uAC00\uC801\uC73C\uB85C \uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407123
    m_Localized: "\uC6CC\uD130\uD3F4"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407124
    m_Localized: "2\uBC88\uC9F8 \uACF5\uACA9\uB9C8\uB2E4, \uAD6C\uB77C\uAC00 \uD30C\uB3C4\uB97C
      \uC77C\uC73C\uCF1C 150%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407125
    m_Localized: "\uC7BD\uC7BD\uC2A4\uD2B8\uB808\uC774\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407126
    m_Localized: "\uCF54\uB85C\uB124\uAC00 3\uBC88\uC5D0 \uAC78\uCCD0 \uACF5\uACA9\uD569\uB2C8\uB2E4.
      \uCCAB 2\uBC88\uC758 \uACF5\uACA9\uC740 100%\uC758 \uD53C\uD574\uB97C, \uB9C8\uC9C0\uB9C9
      \uACF5\uACA9\uC740 200%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407127
    m_Localized: "\uC7BD \uC5F0\uD0C0"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407128
    m_Localized: "4.5\uCD08\uB9C8\uB2E4 \uCF54\uB85C\uB124\uAC00 \uC7BD\uC744 \uC5F0\uD0C0\uD558\uC5EC
      450%\uC758 \uD53C\uD574\uB97C \uB098\uB204\uC5B4 \uC785\uD799\uB2C8\uB2E4.
      \uD328\uD134 \uC9C4\uD589 \uC911\uC5D0\uB3C4 \uC2DC\uC804\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407129
    m_Localized: DOOG PUNCH
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407130
    m_Localized: "\uCF54\uB85C\uB124\uAC00 \uBAAC\uC2A4\uD130\uC5D0\uAC8C \uD53C\uD574\uB97C
      \uC785\uD790 \uB54C \uB9C8\uB2E4, 30% \uD655\uB960\uB85C DOOG PUNCH\uB97C \uC0AC\uC6A9\uD558\uC5EC
      100%\uC758 \uD53C\uD574\uB97C \uCD94\uAC00\uB85C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407131
    m_Localized: "\uD558\uD504 \uC5F0\uC8FC"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407132
    m_Localized: "\uC640\uD0C0\uBA54\uAC00 \uD558\uD504\uB97C \uD295\uACA8 \uBA5C\uB85C\uB514\uB97C
      \uB0A0\uB9BD\uB2C8\uB2E4. \uBA5C\uB85C\uB514\uB294 \uCD5C\uB300 5\uB9C8\uB9AC\uC758
      \uBAAC\uC2A4\uD130\uC5D0\uAC8C 100%\uC758 \uD53C\uD574\uB97C \uC785\uD788\uACE0
      \uC774\uB3D9\uC18D\uB3C4\uB97C \uB290\uB9AC\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407133
    m_Localized: "\uC2E0\uB098\uB294 \uBA5C\uB85C\uB514"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407134
    m_Localized: "\uC640\uD0C0\uBA54\uAC00 \uC2E0\uBE44\uD55C \uC5F0\uC8FC\uBC95\uC73C\uB85C
      \uD558\uD504\uB97C \uD295\uACA8 \uBA5C\uB85C\uB514 \uC7A5\uD310\uC744 \uB9CC\uB4ED\uB2C8\uB2E4.
      \uBA5C\uB85C\uB514 \uC7A5\uD310\uC5D0 \uC788\uB294 \uC720\uB2DB\uC740 \uACF5\uACA9\uC18D\uB3C4\uAC00
      40% \uBE68\uB77C\uC9C0\uBA70, \uBAAC\uC2A4\uD130\uB294 \uC774\uB3D9\uC18D\uB3C4\uAC00
      \uB290\uB824\uC9D1\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784 12\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407135
    m_Localized: "\uC694\uC694 \uACF5\uACA9"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407136
    m_Localized: "\uC2A4\uBC14\uB8E8\uAC00 \uC694\uC694\uB97C \uB358\uC838 \uBAAC\uC2A4\uD130\uB97C
      2\uBC88\uC5D0 \uAC78\uCCD0 200%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4.
      \uCCAB\uBC88\uC9F8 \uACF5\uACA9\uC740 \uBAAC\uC2A4\uD130\uB97C \uBC00\uCCD0\uB0C5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407137
    m_Localized: "\uC288\uBC14\uB355 \uC9C8\uC8FC"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407138
    m_Localized: "\uC288\uBC14\uB355\uC774 \uB4F1\uC7A5\uD574 \uC804\uBC29\uC73C\uB85C
      \uC9C8\uC8FC\uD569\uB2C8\uB2E4. \uC288\uBC14\uB355\uC740 \uBAAC\uC2A4\uD130\uB97C
      \uBC00\uCCD0\uB0B4\uACE0 150%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4
      (\uCFE8\uD0C0\uC784 7\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407139
    m_Localized: "\uC81C\uD2B8\uC5D4\uC9C4 \uC694\uC694"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407140
    m_Localized: "\uC694\uC694\uC758 \uBBF8\uB294 \uD798\uC774 1.5\uBC30 \uC99D\uAC00\uD569\uB2C8\uB2E4(\uC288\uBC14\uB355\uC758
      \uBC00\uCE58\uB294 \uD798\uC740 \uC601\uD5A5\uC744 \uBC1B\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4).
      \uC694\uC694 2\uD0C0\uC758 \uB370\uBBF8\uC9C0\uAC00 50% \uC99D\uAC00\uD569\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407141
    m_Localized: "\uB9AC\uBCFC\uBC84 \uBC1C\uC0AC"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407142
    m_Localized: "\uC653\uC2A8\uC774 \uD0D0\uC815\uC758 \uB9AC\uBCFC\uBC84\uB97C
      \uBC1C\uC0AC\uD558\uC5EC 100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407143
    m_Localized: "\uAE30\uAD00\uCD1D \uB09C\uC0AC"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407144
    m_Localized: "3\uBC88\uC9F8 \uACF5\uACA9\uB9C8\uB2E4, \uC653\uC2A8\uC774 \uAE30\uAD00\uCD1D\uC744
      \uB09C\uC0AC\uD558\uC5EC 20\uD68C\uC5D0 \uAC78\uCCD0 450%\uC758 \uD53C\uD574\uB97C
      \uB098\uB204\uC5B4 \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407145
    m_Localized: "\uC2DC\uAC04 \uAC00\uC18D"
    m_Metadata:
      m_Items: []
  - m_Id: 8043247407146
    m_Localized: "\uC653\uC2A8\uC774 \uC790\uC2E0\uC758 \uD2B9\uBCC4\uD55C \uC2DC\uACC4\uB85C
      \uC2DC\uAC04\uC744 \uAC00\uC18D\uC2DC\uCF1C \uACF5\uACA9\uC18D\uB3C4\uB97C
      15\uCD08\uAC04 40% \uBE60\uB974\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4. \uD328\uD134
      \uC2DC\uC804 \uC2DC \uC8FD\uC740 \uC720\uB2DB\uC774 \uC788\uB2E4\uBA74, \uB79C\uB364\uD55C
      \uB9AC\uC2A4\uD3F0 \uD3EC\uC778\uD2B8 \uD558\uB098\uB97C \uC120\uD0DD\uD558\uC5EC
      \uC0AC\uB9DD \uB300\uAE30\uC2DC\uAC04\uC744 \uC808\uBC18\uC73C\uB85C \uC904\uC785\uB2C8\uB2E4
      (\uCFE8\uD0C0\uC784 20\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 3405470138601472
    m_Localized: "\uB0AB \uD718\uB450\uB974\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 3405470188933120
    m_Localized: "\uCE7C\uB9AC\uC624\uD398\uAC00 \uB0AB\uC744 \uD718\uB458\uB7EC
      100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3405470197321728
    m_Localized: "\uC601\uD63C \uC218\uD655"
    m_Metadata:
      m_Items: []
  - m_Id: 3405470197321729
    m_Localized: "\uCE7C\uB9AC\uC624\uD398\uAC00 \uD544\uB4DC\uC5D0 \uC874\uC7AC\uD560
      \uB54C, \uBAAC\uC2A4\uD130\uAC00 \uC8FD\uC73C\uBA74 5%\uC758 \uD655\uB960\uB85C
      \uC601\uD63C\uC744 \uC5BB\uC2B5\uB2C8\uB2E4. \uC77C\uC815\uB7C9\uC758 \uC601\uD63C\uC744
      \uBAA8\uC744 \uB54C \uB9C8\uB2E4, \uD574\uB2F9 \uAC8C\uC784 \uB3D9\uC548 \uCE7C\uB9AC\uC624\uD398\uC758
      POWER\uAC00 \uC601\uAD6C\uD788 \uC99D\uAC00\uD569\uB2C8\uB2E4 (\uC601\uD63C
      10\uAC1C \uB2F9 POWER 4 \uC99D\uAC00). \n\uBCF4\uC2A4\uB97C \uCC98\uCE58\uD558\uBA74
      100% \uD655\uB960\uB85C \uAC15\uD654\uB41C \uC601\uD63C\uC744 \uC5BB\uC744
      \uC218 \uC788\uC73C\uBA70, \uAC15\uD654\uB41C \uC601\uD63C\uC5D0\uC120 \uC601\uD63C
      50\uAC1C \uBD84\uC758 \uC2A4\uD0DD\uC744 \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3405470197321730
    m_Localized: "\uB370\uC2A4\uC13C\uC138 \uC5D0\uC2A4\uCF54\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 3405470197321731
    m_Localized: "4\uBC88\uC9F8 \uACF5\uACA9\uB9C8\uB2E4, \uCE7C\uB9AC\uC624\uD398\uAC00
      '\uB370\uC2A4\uC13C\uC138'\uB97C \uBD88\uB7EC\uB0C5\uB2C8\uB2E4. \uB370\uC2A4\uC13C\uC138\uB294
      \uCD5C\uCD08\uC5D0 \uC801\uC744 \uBC00\uCCD0\uB0B4\uACE0, \uC804\uBC29\uC5D0
      200%\uC758 \uD53C\uD574\uB97C \uC785\uD788\uB294 '\uB370\uC2A4 \uC2AC\uB798\uC2DC'
      \uD22C\uC0AC\uCCB4\uB97C \uB0A0\uB9AC\uACE0 \uC0AC\uB77C\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 3405470197321732
    m_Localized: "\uB370\uC2A4 \uCF54\uC77C"
    m_Metadata:
      m_Items: []
  - m_Id: 3405470197321733
    m_Localized: "\uCE7C\uB9AC\uC624\uD398\uAC00 \uC790\uC2E0 \uAE30\uC900 8 \uBC29\uD5A5\uC73C\uB85C
      '\uB370\uC2A4 \uCF54\uC77C'\uC744 \uB0A0\uB824\uBCF4\uB0C5\uB2C8\uB2E4. \uB370\uC2A4
      \uCF54\uC77C\uC740 \uAC01\uAC01 100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4
      (\uCFE8\uD0C0\uC784 12\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 3636951524020224
    m_Localized: "\uC591\uACFC \uD568\uAED8"
    m_Metadata:
      m_Items: []
  - m_Id: 3636951578546176
    m_Localized: "\uAC8C\uC784 \uC2DC\uC791 \uC2DC, \uC640\uD0C0\uBA54\uAC00 \uC591\uC744
      \uC18C\uD658\uD569\uB2C8\uB2E4. \uC591\uC740 \uACF5\uACA9 \uB2A5\uB825\uC774
      \uC5C6\uC73C\uBA70, \uCCB4\uB825\uC744 \uD68C\uBCF5\uD560 \uC218 \uC5C6\uB294
      \uB300\uC2E0, \uB9CE\uC740 \uCCB4\uB825\uC744 \uBCF4\uC720\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 10938678543618048
    m_Localized: "\uC5D4\uC824 \uBC30\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 10938678589755392
    m_Localized: "\uCE74\uB098\uD0C0\uAC00 \uBC30\uD2B8\uB97C \uD718\uB458\uB7EC
      100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 10938678589755393
    m_Localized: "\uC5D4\uC824\uB9C1 \uC288\uB9AC\uCF04"
    m_Metadata:
      m_Items: []
  - m_Id: 10938678589755394
    m_Localized: "6.5\uCD08 \uB9C8\uB2E4, \uCE74\uB098\uD0C0\uAC00 \uC5D4\uC824\uB9C1
      \uC288\uB9AC\uCF04\uC744 3\uAC1C \uC18C\uD658\uD569\uB2C8\uB2E4. \uC5D4\uC824\uB9C1
      \uC288\uB9AC\uCF04\uC774 \uC18C\uD658\uB41C \uC0C1\uD0DC\uC5D0\uC11C \uCE74\uB098\uD0C0\uAC00
      \uB2E4\uC74C \uD328\uD134\uC744 \uC2DC\uC804\uD560 \uC2DC, \uC5D4\uC824\uB9C1
      \uC288\uB9AC\uCF04\uC774 \uB0A0\uC544\uAC00 3\uBC88\uC5D0 \uAC78\uCCD0 240%\uC758
      \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 10938678589755395
    m_Localized: "\uC2DC\uC18D 500km \uAC15\uC18D\uD0C0"
    m_Metadata:
      m_Items: []
  - m_Id: 10938678589755396
    m_Localized: "\uCE74\uB098\uD0C0\uAC00 \uACF5\uACA9\uD560 \uB54C \uB9C8\uB2E4
      '\uC5D4\uC824 \uCE74\uC6B4\uD2B8'\uB97C 1\uD68C \uC313\uC744 \uC218 \uC788\uAC8C
      \uB429\uB2C8\uB2E4. \uD328\uD134 \uC2DC\uC804 \uC2DC, \uD604\uC7AC \uAC00\uC9C0\uACE0
      \uC788\uB294 \uBAA8\uB4E0 \uC5D4\uC824 \uCE74\uC6B4\uD2B8\uB97C \uC18C\uBE44\uD558\uACE0
      '\uC18C\uBAA8\uD55C \uC5D4\uC824 \uCE74\uC6B4\uD2B8 X 6 + 200%'\uB9CC\uD07C\uC758
      \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784 15\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 23204322928463872
    m_Localized: "\uB514\uC800\uD2B8 \uD0C0\uC784!"
    m_Metadata:
      m_Items: []
  - m_Id: 23204322974601216
    m_Localized: "\uB8E8\uB098\uAC00 \uB4B7 3\uC5F4\uC758 \uB79C\uB364\uD55C \uD0C0\uC77C\uC5D0
      \uB514\uC800\uD2B8\uB97C \uC18C\uD658\uD569\uB2C8\uB2E4. \uC720\uB2DB\uC774
      \uB514\uC800\uD2B8\uB97C \uC2B5\uB4DD\uD558\uBA74, \uADF8 \uB514\uC800\uD2B8\uC758
      \uC885\uB958\uC5D0 \uB530\uB77C \uB2E4\uC591\uD55C \uBC84\uD504\uB97C \uC5BB\uC744
      \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n- \uB9C8\uCE74\uB871 : \uD68C\uBCF5\uD6A8\uACFC(\uB8E8\uB098
      POWER\uC758 100%)\uC5D0 \uB354\uD574 \uC720\uB2DB\uC758 POWER\uB97C 5\uCD08\uAC04
      50% \uC62C\uB824\uC90D\uB2C8\uB2E4.\n- \uCD08\uCF5C\uB9BF : \uD68C\uBCF5\uD6A8\uACFC(\uB8E8\uB098
      POWER\uC758 100%)\uC5D0 \uB354\uD574 \uC720\uB2DB\uC758 \uACF5\uACA9\uC18D\uB3C4\uB97C
      5\uCD08\uAC04 50% \uC62C\uB824\uC90D\uB2C8\uB2E4.\n- \uC9C4\uC800\uB9E8 : \uD68C\uBCF5\uD6A8\uACFC(\uB8E8\uB098
      POWER\uC758 100%)\uC5D0 \uB354\uD574 \uC720\uB2DB\uC758 HP\uB97C 5\uCD08\uAC04
      50% \uC62C\uB824\uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 23204322974601217
    m_Localized: "\uB3C4\uC640\uC918, \uB8E8\uB098\uC774\uD2B8!"
    m_Metadata:
      m_Items: []
  - m_Id: 23204322974601218
    m_Localized: "\uB8E8\uB098\uC774\uD2B8\uAC00 \uB8E8\uB098\uC758 \uBD80\uB984\uC5D0
      \uC751\uD574 \uB8E8\uB098\uB97C \uC9C0\uD0A4\uB7EC \uB0A0\uB77C\uC635\uB2C8\uB2E4.
      \uB8E8\uB098\uC774\uD2B8\uB294 \uCC98\uC74C \uBD80\uB52A\uD78C \uBAAC\uC2A4\uD130\uC5D0\uAC8C
      50%\uC758 \uD53C\uD574\uB97C \uC785\uD78C \uD6C4, \uD574\uB2F9 \uBAAC\uC2A4\uD130\uC758
      \uB4B7 \uCE78\uC5D0 \uCC29\uC9C0\uD569\uB2C8\uB2E4. \uC774 \uD6C4, 2\uBC88\uC758
      \uAC78\uCCD0 60%\uC758 \uD53C\uD574\uB97C \uB098\uB204\uC5B4 \uC785\uD788\uACE0,
      \uB9C8\uC9C0\uB9C9 \uACF5\uACA9\uC73C\uB85C 3X3 \uBC94\uC704\uC5D0 60%\uC758
      \uD53C\uD574\uC640 \uD568\uAED8 \uBAAC\uC2A4\uD130\uB97C \uAE30\uC808\uC2DC\uD0A4\uACE0
      \uC0AC\uB77C\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 23204322974601219
    m_Localized: "\uB8E8\uB098\uD0C0\uC784"
    m_Metadata:
      m_Items: []
  - m_Id: 23204322974601220
    m_Localized: "\uB8E8\uB098\uAC00 10\uBC88\uC9F8 \uB514\uC800\uD2B8\uB97C '\uB9C8\uBC95\uC0AC\uD0D5'\uC73C\uB85C
      \uC18C\uD658\uD560 \uC218 \uC788\uAC8C \uB429\uB2C8\uB2E4. \uB9C8\uBC95\uC0AC\uD0D5\uC740
      \uC5B4\uB5A4 \uC720\uB2DB\uC774 \uC2B5\uB4DD\uD558\uB290\uB0D0\uC5D0 \uB530\uB77C
      \uD6A8\uACFC\uAC00 \uBCC0\uACBD\uB429\uB2C8\uB2E4.\n- \uB8E8\uB098 \uC774\uC678\uC758
      \uC720\uB2DB\uC774 \uD68D\uB4DD\uD560 \uC2DC : \uB8E8\uB098\uB97C \uC81C\uC678\uD55C
      \uBAA8\uB4E0 \uC720\uB2DB\uC758 POWER, \uACF5\uACA9\uC18D\uB3C4, HP\uB97C 10\uCD08\uAC04
      50% \uC62C\uB824\uC90D\uB2C8\uB2E4.\n- \uB8E8\uB098\uAC00 \uD68D\uB4DD\uD560
      \uC2DC : \uB8E8\uB098\uAC00 \uC704\uC758 \uBC84\uD504\uD6A8\uACFC\uC640 \uD568\uAED8
      '\uB8E8\uB098\uD0C0\uC784'\uC5D0 \uB3CC\uC785\uD569\uB2C8\uB2E4. \uB8E8\uB098\uD0C0\uC784
      \uB3CC\uC785 \uC2DC \uB79C\uB364\uD55C 10\uAC1C\uC758 \uD0C0\uC77C\uC5D0 \uB8E8\uB098\uC774\uD2B8\uB97C
      \uC18C\uD658\uD558\uBA70, \uC9C0\uC18D\uC2DC\uAC04\uB3D9\uC548 \uAE30\uBCF8
      \uD328\uD134\uC774 '\uB3C4\uC640\uC918, \uB8E8\uB098\uC774\uD2B8!'\uB85C \uB300\uCCB4\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 33428040371900416
    m_Localized: "\uD6C4\uBD80\uD0A4\uAC00 \uC804\uBC29\uC5D0 \uD560\uD034\uAE30
      \uACF5\uACA9\uC73C\uB85C 100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 33428040409649152
    m_Localized: "\uC5EC\uC6B0 \uD560\uD034\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 33428040409649153
    m_Localized: "\uD6C4\uBD80\uD0A4\uAC00 \uCE74\uD0C0\uB098\uB97C \uBE7C\uB4E4\uC5B4
      \uC804\uBC29\uC5D0 150%\uC758 \uD53C\uD574\uB97C \uC8FC\uB294 \uAC80\uD48D\uC744
      \uB0A0\uB9BD\uB2C8\uB2E4. \uC774 \uD328\uD134 \uC0AC\uC6A9 \uC2DC \uD751\uD654
      \uAC8C\uC774\uC9C0\uB97C 2% \uD68C\uBCF5\uD569\uB2C8\uB2E4.\n\n(\uCFE0\uB85C\uCE74\uBBF8
      \uBCC0\uC2E0\uC911\uC77C \uB54C) \uC804\uBC29\uC5D0 150%\uC758 \uD53C\uD574\uB97C
      \uC8FC\uB294 \uAC80\uD48D\uC744 2\uAC1C \uB0A0\uB9BD\uB2C8\uB2E4. \uD751\uD654
      \uAC8C\uC774\uC9C0\uB97C \uD68C\uBCF5\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 33428040409649154
    m_Localized: "\uBC14\uB78C \uAC00\uB974\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 33428040409649155
    m_Localized: "(\uCFE0\uB85C\uCE74\uBBF8 \uBCC0\uC2E0\uC911\uC77C \uB54C \uC0AC\uC6A9\uAC00\uB2A5)
      \uCFE0\uB85C\uCE74\uBBF8\uAC00 \uC5F0\uC18D\uC73C\uB85C \uD560\uD034\uAE30
      \uACF5\uACA9\uC744 \uC2DC\uC804\uD558\uC5EC \uCD1D 280%\uC758 \uD53C\uD574\uB97C
      \uC785\uD799\uB2C8\uB2E4. \uD6C4\uBD80\uD0A4\uB294 \uC774 \uACF5\uACA9\uC73C\uB85C
      \uC785\uD78C \uD53C\uD574\uC758 1/3\uC744 HP\uB85C \uD68C\uBCF5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 33428040409649156
    m_Localized: "\uAD11\uB780\uC758 \uD560\uD034\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 33428040409649157
    m_Localized: "\uD6C4\uBD80\uD0A4\uAC00 \uD751\uD654 \uAC8C\uC774\uC9C0\uB97C
      \uC0AC\uC6A9\uD569\uB2C8\uB2E4. \uD6C4\uBD80\uD0A4\uB294 \uC77C\uC815\uC2DC\uAC04\uB9C8\uB2E4
      \uAC8C\uC774\uC9C0\uB97C \uC2A4\uC2A4\uB85C \uD68C\uBCF5\uD558\uBA70, \uD751\uD654
      \uAC8C\uC774\uC9C0\uAC00 \uC788\uB294 \uB3D9\uC548 \uCFE0\uB85C\uCE74\uBBF8
      \uD6C4\uBD80\uD0A4\uB85C \uBCC0\uC2E0\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uBCC0\uC2E0 \uC911\uC5D0\uB294 \uACF5\uACA9\uC18D\uB3C4\uAC00 50% \uC99D\uAC00\uD569\uB2C8\uB2E4.\n\n\uCFE0\uB85C\uCE74\uBBF8\uB85C
      \uBCC0\uC2E0\uC911\uC77C \uB550 \uAC8C\uC774\uC9C0\uAC00 \uC11C\uC11C\uD788
      \uAC10\uC18C\uD558\uBA70, \uAC8C\uC774\uC9C0\uAC00 0\uC774 \uB420 \uC2DC \uC989\uC2DC
      \uC2DC\uB77C\uCE74\uBBF8\uB85C \uB2E4\uC2DC \uBCC0\uD558\uACE0 15\uCD08\uAC04
      \uD734\uC9C0 \uC0C1\uD0DC\uC5D0 \uBE60\uC9D1\uB2C8\uB2E4. \uD734\uC9C0 \uC0C1\uD0DC\uC77C
      \uB550 \uCFE0\uB85C\uCE74\uBBF8\uB85C \uBCC0\uD560 \uC218 \uC5C6\uC73C\uBA70,
      \uD734\uC9C0 \uC0C1\uD0DC\uAC00 \uB05D\uB098\uBA74 \uAC8C\uC774\uC9C0\uB97C
      30% \uD68C\uBCF5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 33428040409649158
    m_Localized: "\uCFE0\uB85C\uCE74\uBBF8 \uD6C4\uBD80\uD0A4"
    m_Metadata:
      m_Items: []
  - m_Id: 41341107852251136
    m_Localized: "\uB808\uC774\uC800 \uB77C\uC774\uD50C"
    m_Metadata:
      m_Items: []
  - m_Id: 41341107902582784
    m_Localized: "\uD1A0\uC640\uAC00 \uC804\uBC29\uC5D0 \uB808\uC774\uC800 \uB77C\uC774\uD50C
      \uD0C4\uD658\uC744 \uBC1C\uC0AC\uD558\uC5EC \uCD5C\uB300 3\uBA85\uC758 \uBAAC\uC2A4\uD130\uC5D0\uAC8C
      100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 41341107906777088
    m_Localized: "\uC18C\uC545\uB9C8\uC758 \uD0A4\uC2A4"
    m_Metadata:
      m_Items: []
  - m_Id: 41341107906777089
    m_Localized: "4\uBC88\uC9F8 \uACF5\uACA9\uB9C8\uB2E4 \uD1A0\uC640\uAC00 \uC804\uBC29\uC5D0
      \uAC15\uB825\uD55C \uB808\uC774\uC800\uB97C \uC3D8\uC544 \uC801 \uBAAC\uC2A4\uD130\uC5D0\uAC8C
      200%\uC758 \uD53C\uD574\uB97C \uC785\uD788\uACE0, \uC544\uAD70\uC758 \uCCB4\uB825\uC744
      \uD68C\uBCF5(\uD68C\uBCF5\uB7C9 : \uD1A0\uC640 POWER\uC758 50%)\uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 41341107906777090
    m_Localized: "\uB9E4\uD639\uC758 \uC774\uB04C\uB9BC"
    m_Metadata:
      m_Items: []
  - m_Id: 41341107906777091
    m_Localized: "\uD1A0\uC640\uAC00 \uC804\uBC29\uC5D0 \uC218\uB958\uD0C4\uC744
      \uD22C\uCC99\uD569\uB2C8\uB2E4. \uC218\uB958\uD0C4\uC740 \uCC98\uC74C \uBAAC\uC2A4\uD130\uC5D0\uAC8C
      \uB2FF\uC740 \uC9C0\uC810\uC5D0\uC11C '\uBE14\uB799\uD640' \uC624\uBE0C\uC81D\uD2B8\uB97C
      \uC0DD\uC131\uD569\uB2C8\uB2E4. \uBE14\uB799\uD640\uC740 3X3 \uBC94\uC704 \uB0B4\uC5D0
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB97C \uC9C0\uC18D\uC801\uC73C\uB85C \uB04C\uC5B4\uB2F9\uAE30\uBA70,
      \uCD1D 300%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784
      18\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 43790346188460032
    m_Localized: "\uACE0\uB300\uC758 \uAE43\uD138"
    m_Metadata:
      m_Items: []
  - m_Id: 43790346230403072
    m_Localized: "\uBB34\uBA54\uC774\uAC00 \uD2B9\uBCC4\uD55C \uD798\uC774 \uB2F4\uAE34
      '\uAE43\uD138 \uD22C\uC0AC\uCCB4' \uD558\uB098\uB97C \uB0A0\uB824 100%\uC758
      \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 43790346230403073
    m_Localized: "\uAE43\uD138 \uD3ED\uBC1C"
    m_Metadata:
      m_Items: []
  - m_Id: 43790346230403074
    m_Localized: "\uAE43\uD138 \uD22C\uC0AC\uCCB4\uAC00 \uBAAC\uC2A4\uD130\uC5D0\uAC8C
      \uC801\uC911\uD560 \uB54C \uB9C8\uB2E4, \uBAAC\uC2A4\uD130\uC5D0\uAC8C \uAE43\uD138\uC774
      1\uAC1C \uAF43\uD788\uAC8C \uB429\uB2C8\uB2E4. \uAE43\uD138\uC774 3\uAC1C \uAF43\uD614\uC744
      \uB54C, \uC801\uC5D0\uAC8C 150%\uC758 \uD53C\uD574\uB97C \uC785\uD788\uACE0
      \uAF43\uD78C \uAE43\uD138\uC744 \uBAA8\uB450 \uC81C\uAC70\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 43790346230403075
    m_Localized: "\uC720\uB300\uC758 \uD798"
    m_Metadata:
      m_Items: []
  - m_Id: 43790346230403076
    m_Localized: "\uBB34\uBA54\uC774\uAC00 \uCE5C\uAD6C\uC758 \uD798\uC744 \uC77C\uAE68\uC6CC
      \uAE30\uBCF8 \uD328\uD134\uC744 \uAC15\uD654\uD569\uB2C8\uB2E4. 10\uCD08 \uB3D9\uC548
      \uACF5\uACA9\uC18D\uB3C4\uAC00 30% \uC99D\uAC00\uD558\uACE0, \uAE30\uBCF8 \uD328\uD134\uC758
      \uBC1C\uC0AC \uAC00\uB2A5\uD55C \uAE43\uD138 \uD22C\uC0AC\uCCB4\uAC00 3\uAC1C\uB85C
      \uC99D\uAC00\uD569\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784 15\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 43790346230403077
    m_Localized: "\uAE43\uD138 \uAF43"
    m_Metadata:
      m_Items: []
  - m_Id: 43790346230403078
    m_Localized: "\uAE43\uD138 \uD3ED\uBC1C\uC758 \uB370\uBBF8\uC9C0\uAC00 250%\uB85C
      \uC99D\uAC00\uD569\uB2C8\uB2E4. \uAE43\uD138 \uD3ED\uBC1C\uC774 \uBC1C\uC0DD\uD560
      \uB54C \uB9C8\uB2E4, \uBAAC\uC2A4\uD130 \uB4A4\uB85C '\uAD00\uD1B5\uB41C \uAE43\uD138
      \uD22C\uC0AC\uCCB4' 5\uBC1C\uC774 \uCD94\uAC00\uB85C \uBC1C\uC0AC\uB429\uB2C8\uB2E4.
      \uAD00\uD1B5\uB41C \uAE43\uD138 \uD22C\uC0AC\uCCB4\uB294 50%\uC758 \uB370\uBBF8\uC9C0\uB97C
      \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 49851155280793600
    m_Localized: "\uB208\uC18D\uC5D0 \uD540 \uAF43"
    m_Metadata:
      m_Items: []
  - m_Id: 49851155331125248
    m_Localized: "\uB77C\uBBF8\uB294 \uC9C0\uC18D\uC801\uC73C\uB85C \uB208\uBCF4\uB77C\uB97C
      \uC77C\uC73C\uCF1C 3X3 \uBC94\uC704 \uB0B4\uC758 \uBAAC\uC2A4\uD130\uB4E4\uC5D0\uC5D0\uAC8C
      20%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 49851155331125249
    m_Localized: "\uC11C\uB9AC\uD3ED\uBC1C"
    m_Metadata:
      m_Items: []
  - m_Id: 49851155331125250
    m_Localized: "\uB77C\uBBF8\uAC00 \uC11C\uB9AC\uD3ED\uBC1C\uC744 \uC77C\uC73C\uCF1C
      3X3 \uBC94\uC704 \uB0B4\uC758 \uBAAC\uC2A4\uD130\uB4E4\uC5D0\uAC8C 100%\uC758
      \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4. \uBD88 \uC7A5\uD310 \uC0C1\uD0DC\uC5D0\uC120
      \uD654\uC5FC\uD3ED\uBC1C\uB85C \uAD50\uCCB4\uB418\uBA70, 5X5 \uBC94\uC704 \uB0B4\uC758
      \uBAAC\uC2A4\uD130\uB4E4\uC5D0\uAC8C 200%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 49851155331125251
    m_Localized: "\uCCAD\uC8FC\uD55C\uBCD1"
    m_Metadata:
      m_Items: []
  - m_Id: 49851155331125252
    m_Localized: "20\uCD08\uB9C8\uB2E4 \uB77C\uBBF8\uAC00 \uCCAD\uC8FC\uB97C \uB4E4\uC774\uCF1C
      \uCD94\uC704\uB97C \uC78A\uACE0, \uB208\uBCF4\uB77C\uB97C \uBD88 \uC7A5\uD310\uC73C\uB85C
      \uAD50\uCCB4\uD569\uB2C8\uB2E4. \uBD88 \uC7A5\uD310\uC740 5X5 \uBC94\uC704\uC5D0
      \uC788\uB294 \uBAAC\uC2A4\uD130\uB4E4\uC5D0\uAC8C 40%\uC758 \uD53C\uD574\uB97C
      \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 49851155331125253
    m_Localized: "\uB208\uBCF4\uB77C"
    m_Metadata:
      m_Items: []
  - m_Id: 49851155331125254
    m_Localized: "\uB77C\uBBF8\uAC00 \uC5BC\uC74C\uC73C\uB85C \uC790\uC2E0\uC744
      \uAC10\uC2F8 6\uCD08 \uB3D9\uC548 \uD53C\uD574\uB97C \uC785\uC9C0 \uC54A\uC73C\uBA70,
      \uB208\uBCF4\uB77C\uB97C \uC77C\uC73C\uCF1C \uB9F5 \uC804\uCCB4\uC5D0 \uCD1D
      900%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784
      35\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 52469118219554816
    m_Localized: "\uBA5C\uB85C\uB514"
    m_Metadata:
      m_Items: []
  - m_Id: 52469118269886464
    m_Localized: "\uC2A4\uC774\uC138\uC774\uAC00 \uB178\uB798\uB97C \uBD88\uB7EC
      \uC74C\uD30C \uACF5\uACA9\uC744 \uC2DC\uC804\uD558\uC5EC 100%\uC758 \uD53C\uD574\uB97C
      \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 52469118269886465
    m_Localized: "\uC2A4\uC774\uCF54\uD328\uC2A4"
    m_Metadata:
      m_Items: []
  - m_Id: 52469118269886466
    m_Localized: "\uC2A4\uC774\uC138\uC774\uAC00 \uAE08\uB3C4\uB07C\uB97C \uB358\uC838
      150%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4. \uAE08\uB3C4\uB07C
      \uD22C\uC0AC\uCCB4\uB294 \uB9F5 \uB05D\uC5D0 \uB2FF\uC744 \uB54C \uB9C8\uB2E4
      \uD295\uAE30\uBA70, 7\uCD08 \uB3D9\uC548 \uC874\uC18D\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 52469118269886467
    m_Localized: "\uBCC4\uC758 \uC870\uAC01"
    m_Metadata:
      m_Items: []
  - m_Id: 52469118269886468
    m_Localized: "\uC2A4\uC774\uC138\uC774\uAC00 \uD558\uB298\uC5D0\uC11C \uBCC4\uC758
      \uC870\uAC01\uC744 \uB5A8\uC5B4\uD2B8\uB824 300%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4.
      \uC774 \uD328\uD134\uC73C\uB85C \uBAAC\uC2A4\uD130\uB97C \uCC98\uCE58\uD558\uBA74
      \uBCC4\uAC00\uB8E8 \uC2A4\uD0DD\uC744 \uC5BB\uC744 \uC218 \uC788\uC73C\uBA70,
      \uBCC4\uAC00\uB8E8 \uC2A4\uD0DD\uC774 50\uC774 \uB410\uC744 \uB54C \uD328\uD134\uC774
      '\uD61C\uC131' \uD328\uD134\uC73C\uB85C \uAD50\uCCB4\uB429\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784
      12\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 52469118269886469
    m_Localized: "\uD61C\uC131"
    m_Metadata:
      m_Items: []
  - m_Id: 52469118269886470
    m_Localized: "\uC2A4\uC774\uC138\uC774\uAC00 \uD61C\uC131\uC744 \uD544\uB4DC\uC5D0
      \uB5A8\uC5B4\uD2B8\uB824 \uBAA8\uB4E0 \uBAAC\uC2A4\uD130\uC5D0\uAC8C 600%\uC758
      \uD53C\uD574\uB97C \uC8FC\uACE0 5\uCD08\uAC04 \uAE30\uC808\uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 63813857250349056
    m_Localized: "\uC0DD\uBA85\uC758 \uB098\uBB34"
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292096
    m_Localized: "\uD30C\uC6B0\uB098\uAC00 \uC0DD\uBA85\uC758 \uB098\uBB34\uB97C
      \uC131\uC7A5\uC2DC\uD0B5\uB2C8\uB2E4. \uB098\uBB34\uB294 \uCD5C\uB300 3\uB2E8\uACC4\uAE4C\uC9C0
      \uC790\uB77C\uBA70, 3\uB2E8\uACC4\uC5D0\uC11C \uB2E4\uC2DC \uAE30\uBCF8 \uD328\uD134
      \uC0AC\uC6A9 \uC2DC '\uC0DD\uBA85\uC758 \uBC14\uB78C'\uC774 \uBD88\uC5B4 5x5
      \uBC94\uC704 \uB0B4 \uC544\uAD70 \uC720\uB2DB\uB4E4\uC744 \uD68C\uBCF5\uC2DC\uD0B5\uB2C8\uB2E4.
      \uC774 \uD6C4 \uB098\uBB34\uB294 \uC0AC\uB77C\uC9C0\uACE0, \uB2E4\uC74C \uAE30\uBCF8
      \uD328\uD134 \uC2DC\uC804 \uC2DC 1\uB2E8\uACC4\uBD80\uD130 \uB2E4\uC2DC \uC790\uB77C\uAE30
      \uC2DC\uC791\uD569\uB2C8\uB2E4. (\uD68C\uBCF5\uB7C9 : \uD30C\uC6B0\uB098\uC758
      POWER 100%)."
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292097
    m_Localized: "\uD30C\uC885"
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292098
    m_Localized: "\uC0DD\uBA85\uC758 \uBC14\uB78C'\uC774 \uC77C \uB54C \uB9C8\uB2E4,
      \uD68C\uBCF5 \uD6A8\uACFC\uB97C \uBC1B\uB294 \uBAA8\uB4E0 \uC720\uB2DB\uB4E4\uC5D0\uAC8C
      \uD30C\uC885\uC744 \uC2DC\uC804\uD569\uB2C8\uB2E4. \uD30C\uC885\uC744 \uBC1B\uC740
      \uC720\uB2DB\uC740 \uD30C\uC6B0\uB098\uC640 \uAC19\uC774 \uC2DD\uBB3C\uC744
      \uD0A4\uC6B8 \uC218 \uC788\uC73C\uBA70, \uAC01 \uC720\uB2DB\uC758 \uC5ED\uD560\uAD70\uC5D0
      \uB530\uB77C \uB2E4\uB978 \uC528\uC557\uC744 \uBC1B\uC2B5\uB2C8\uB2E4. \uC2DD\uBB3C\uB4E4\uC740
      \uD30C\uC6B0\uB098\uC758 \uC0DD\uBA85\uC758 \uB098\uBB34\uAC00 \uC790\uB784
      \uB54C \uB9C8\uB2E4 \uAC19\uC774 \uC790\uB77C\uB098\uBA70, \uB9C8\uCC2C\uAC00\uC9C0\uB85C
      3\uB2E8\uACC4\uAE4C\uC9C0 \uC790\uB780 \uC774\uD6C4 3x3 \uBC94\uC704 \uB0B4\uC5D0
      \uC788\uB294 \uC720\uB2DB\uB4E4\uC5D0\uAC8C \uBC84\uD504 \uD6A8\uACFC\uB97C
      \uC81C\uACF5\uD569\uB2C8\uB2E4. \uD30C\uC6B0\uB098 \uC790\uC2E0\uC740 \uBC84\uD504
      \uD6A8\uACFC\uB97C \uBC1B\uC744 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292099
    m_Localized: "\uAE09\uC18D\uC131\uC7A5"
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292100
    m_Localized: "\uD30C\uC6B0\uB098\uAC00 4\uCD08\uB3D9\uC548 \uC804\uBC29\uC5D0
      \uB098\uBB34 \uBCBD\uC744 \uC138\uC6CC \uBAAC\uC2A4\uD130\uB4E4\uC758 \uC9C4\uCD9C\uC744
      \uB9C9\uC2B5\uB2C8\uB2E4. \uB098\uBB34 \uBCBD\uC774 \uC788\uB294 \uB3D9\uC548,
      \uD30C\uC6B0\uB098\uB97C \uD3EC\uD568\uD55C \uBAA8\uB4E0 \uC720\uB2DB\uB4E4\uC758
      \uACF5\uACA9\uC18D\uB3C4\uAC00 80% \uC99D\uAC00\uD569\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784
      20\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292101
    m_Localized: "\uC880\uBE44 \uD560\uD034\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292102
    m_Localized: "\uC62C\uB9AC\uAC00 \uC804\uBC29\uC73C\uB85C \uD560\uD034\uAE30
      \uACF5\uACA9\uC744 \uC2DC\uC804\uD558\uC5EC 100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292103
    m_Localized: "\uB048\uC9C8\uAE34 \uC0DD\uBA85\uB825"
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292104
    m_Localized: "\uC62C\uB9AC\uAC00 \uD53C\uD574\uB97C \uC785\uD790 \uB54C \uB9C8\uB2E4,
      \uADF8 \uD53C\uD574\uC758 5%\uB97C HP\uB85C \uD68C\uBCF5\uD569\uB2C8\uB2E4.
      \uB300\uC2E0, \uC62C\uB9AC\uB294 \uAE30\uBCF8 HP \uC7AC\uC0DD\uC744 \uD558\uC9C0
      \uBABB\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292105
    m_Localized: Zomrade
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292106
    m_Localized: "4\uBC88\uC9F8 \uACF5\uACA9\uB9C8\uB2E4 \uC62C\uB9AC\uAC00 \uC790\uC2E0\uC758
      \uC704\uCE58\uC5D0 Zomrade\uB97C \uC18C\uD658\uD569\uB2C8\uB2E4. Zomrade\uB294
      \uC77C\uC815\uB7C9\uC758 \uD53C\uD574\uB97C \uC785\uC744 \uB54C \uB9C8\uB2E4
      \uC810\uC810 \uCEE4\uC9C0\uBA70, \uCD5C\uB300\uB85C \uCEE4\uC84C\uC744 \uB54C
      1\uCD08 \uB4A4 \uD3ED\uBC1C\uD558\uC5EC 250%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4.
      Zomrade\uB294 \uC18C\uD658 \uD6C4 7\uCD08\uAC00 \uC9C0\uB09C \uC2DC\uC810\uC5D0\uB294
      \uC790\uB3D9\uC73C\uB85C \uD3ED\uBC1C\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292107
    m_Localized: "\uD23C\uC2A4\uD1A4"
    m_Metadata:
      m_Items: []
  - m_Id: 63813857292292108
    m_Localized: "\uC62C\uB9AC\uAC00 \uC790\uC2E0\uC758 \uC704\uCE58\uC5D0 \uD23C\uC2A4\uD1A4\uC744
      \uC18C\uD658\uD569\uB2C8\uB2E4. \uD23C\uC2A4\uD1A4\uC5D0\uC120 10\uCD08\uB9C8\uB2E4
      \uC778\uD615\uC880\uBE44(UDIN)\uAC00 \uC18C\uD658\uB418\uC5B4 \uC801 \uBAAC\uC2A4\uD130\uC640
      \uC2F8\uC6CC\uC90D\uB2C8\uB2E4. 20% \uD655\uB960\uB85C \uAC15\uD654\uB41C \uD23C\uC2A4\uD1A4\uC774
      \uB4F1\uC7A5\uD560 \uC218 \uC788\uC73C\uBA70, \uAC15\uD654\uB41C \uD23C\uC2A4\uD1A4\uC5D0\uC120
      \uC2A4\uD0EF\uC774 \uB354\uC6B1 \uB354 \uAC15\uD654\uB41C \uAC70\uB300 \uC778\uD615\uC880\uBE44\uAC00
      \uB4F1\uC7A5\uD569\uB2C8\uB2E4. \uC778\uD615\uC880\uBE44\uB4E4\uC758 HP\uC640
      POWER\uB294 \uC62C\uB9AC\uC758 HP\uC640 POWER\uC5D0 \uBE44\uB840\uD569\uB2C8\uB2E4.
      \uBE44\uC11D\uC740 240\uCD08 \uB3D9\uC548 \uC874\uC18D\uD558\uBA70, \uC62C\uB9AC\uAC00
      \uB9AC\uD0C0\uC774\uC5B4 \uD560 \uC2DC \uC18C\uD658\uB418\uC5B4 \uC788\uB358
      \uBAA8\uB4E0 \uBE44\uC11D\uC774 \uC0AC\uB77C\uC9D1\uB2C8\uB2E4 (\uCFE8\uD0C0\uC784
      22\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 65318533254844416
    m_Localized: "\uBB3C\uCD1D"
    m_Metadata:
      m_Items: []
  - m_Id: 65318533292593152
    m_Localized: "\uCF54\uBCF4\uAC00 \uC6B0\uC0B0\uC73C\uB85C \uBB3C\uD3ED\uD0C4\uC744
      \uBC1C\uC0AC\uD569\uB2C8\uB2E4. \uBB3C\uD3ED\uD0C4\uC740 100%\uC758 \uD53C\uD574\uB97C
      \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 65318533292593153
    m_Localized: "\uC370\uBB3C"
    m_Metadata:
      m_Items: []
  - m_Id: 65318533292593154
    m_Localized: "\uBB3C\uD3ED\uD0C4 \uD22C\uC0AC\uCCB4\uAC00 \uD654\uBA74 \uBC16\uC73C\uB85C
      \uBC97\uC5B4\uB098\uBA74, \uBB3C \uD30C\uB3D9 \uD22C\uC0AC\uCCB4\uAC00 \uB418\uC5B4
      \uCF54\uBCF4\uC5D0\uAC8C \uB2E4\uC2DC \uB3CC\uC544\uC635\uB2C8\uB2E4. \uBB3C
      \uD30C\uB3D9 \uD22C\uC0AC\uCCB4\uB294 200%\uC758 \uD53C\uD574\uB97C \uC785\uD788\uBA70,
      \uBAAC\uC2A4\uD130\uB97C 3\uCD08\uAC04 30% \uB290\uB9AC\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 65318533296787456
    m_Localized: "\uB808\uC778 \uC0E4\uBA3C"
    m_Metadata:
      m_Items: []
  - m_Id: 65318533296787457
    m_Localized: "\uCF54\uBCF4\uAC00 10\uCD08 \uB3D9\uC548 \uC9C0\uC18D\uB418\uB294
      \uBE44\uAD6C\uB984\uC744 \uBD88\uB7EC\uB0C5\uB2C8\uB2E4. \uBE44\uAD6C\uB984\uC740
      \uBAAC\uC2A4\uD130\uB4E4\uC5D0\uAC8C 0.3\uCD08\uB9C8\uB2E4 15%\uC758 \uD53C\uD574\uB97C
      \uC785\uD788\uBA70, \uB9C8\uC6B0\uC2A4\uB85C \uC704\uCE58\uB97C \uC870\uC885\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uB9C8\uC6B0\uC2A4 \uD074\uB9AD \uC2DC \uBE44\uAD6C\uB984\uC774
      \uBC88\uAC1C\uB97C \uB0B4\uB9AC\uCCD0 \uBC94\uC704\uB0B4\uC758 \uBAAC\uC2A4\uD130\uB4E4\uC5D0\uAC8C
      250%\uC758 \uD53C\uD574\uB97C \uC785\uD798\uACFC \uB3D9\uC2DC\uC5D0 2\uCD08\uAC04
      \uC2A4\uD134\uC2DC\uD0B5\uB2C8\uB2E4. \uBC88\uAC1C\uB294 \uCD1D 3\uD68C \uC0AC\uC6A9\uD560
      \uC218 \uC788\uC73C\uBA70, \uBC88\uAC1C\uB97C \uBAA8\uB450 \uC0AC\uC6A9\uD560
      \uC2DC \uBE44\uAD6C\uB984\uC774 \uC989\uC2DC \uC0AC\uB77C\uC9D1\uB2C8\uB2E4
      (\uCFE8\uD0C0\uC784 27\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 85394320259518464
    m_Localized: "\uD30C\uD2B8\uB108 \uC9C0\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655808
    m_Localized: "\uC18C\uB77C\uAC00 \uC804\uBC29\uC5D0 \uC788\uB294 \uC720\uB2DB\uC744
      \uD30C\uD2B8\uB108\uB85C \uC9C0\uC815\uD569\uB2C8\uB2E4. \uC774\uBBF8 \uD30C\uD2B8\uB108\uB85C
      \uC9C0\uC815\uB41C \uC720\uB2DB\uC774 \uC788\uB2E4\uBA74, \uC804\uBC29\uC5D0
      \uC788\uB294 \uC720\uB2DB\uC744 \uD30C\uD2B8\uB108\uB85C \uC0C8\uB86D\uAC8C
      \uC9C0\uC815\uD558\uACE0 \uC774\uC804 \uD30C\uD2B8\uB108 \uD6A8\uACFC\uB97C
      \uD574\uC81C\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655809
    m_Localized: "\uD30C\uD2B8\uB108"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655810
    m_Localized: "\uC18C\uB77C\uB294 \uAE30\uBCF8\uD328\uD134\uC73C\uB85C \uD30C\uD2B8\uB108\uB97C
      \uC9C0\uC815\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uD30C\uD2B8\uB108\uB85C
      \uC9C0\uC815\uB41C \uC720\uB2DB\uC740 \uC18C\uB77C\uAC00 '\uD30C\uD2B8\uB108
      \uC9C0\uC815'\uC744 \uC2DC\uC804\uD560 \uB54C \uB9C8\uB2E4 HP\uAC00 \uD68C\uBCF5\uB418\uACE0
      \uACF5\uACA9\uC18D\uB3C4\uAC00 3\uCD08\uAC04 50% \uC99D\uAC00\uD569\uB2C8\uB2E4.
      (\uD68C\uBCF5\uB7C9: POWER\uC758 100%)"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655811
    m_Localized: "\uC2A4\uD0C0 \uBC84\uBE14"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655812
    m_Localized: "\uD30C\uD2B8\uB108\uAC00 \uD53C\uD574\uB97C \uC785\uD790 \uB54C
      \uB9C8\uB2E4, \uC804\uBC29\uC5D0 '\uC2A4\uD0C0 \uBC84\uBE14' \uD22C\uC0AC\uCCB4\uB97C
      \uBC1C\uC0AC\uD569\uB2C8\uB2E4. '\uC2A4\uD0C0 \uBC84\uBE14' \uD22C\uC0AC\uCCB4\uB294
      20%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655813
    m_Localized: "\uC544\uC774\uB3CC \uC628 \uC2A4\uD14C\uC774\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655814
    m_Localized: "\uC18C\uB77C\uAC00 4\uAC1C\uC758 \uBC1C\uD310\uC744 \uC21C\uCC28\uC801\uC73C\uB85C
      \uC0DD\uC131\uD569\uB2C8\uB2E4. \uC18C\uB77C\uAC00 \uBC1C\uD310\uC744 \uBAA8\uB450
      \uBC1F\uB294 \uB370 \uC131\uACF5\uD558\uBA74, 12\uCD08\uAC04 \uC18C\uB77C\uB97C
      \uC81C\uC678\uD55C \uBAA8\uB4E0 \uC720\uB2DB\uC744 \uD30C\uD2B8\uB108\uB85C
      \uC9C0\uC815\uD569\uB2C8\uB2E4. \uB354\uBD88\uC5B4, \uC9C0\uC18D\uC2DC\uAC04\uB3D9\uC548
      \uD30C\uD2B8\uB108 \uBC84\uD504\uC758 \uD6A8\uACFC\uAC00 \uAC15\uD654\uB429\uB2C8\uB2E4
      (\uCFE8\uD0C0\uC784 45\uCD08)."
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655815
    m_Localized: "\uBC9A\uAF43\uD63C\uC5FC"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655816
    m_Localized: "\uBBF8\uCF54\uAC00 \uC804\uBC29\uC5D0 \uBC9A\uAF43\uD63C\uC5FC
      \uD22C\uC0AC\uCCB4\uB97C \uBC1C\uC0AC\uD569\uB2C8\uB2E4. \uD22C\uC0AC\uCCB4\uB294
      100%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655817
    m_Localized: "\uC6B4\uC138\uC885\uC774"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655818
    m_Localized: "\uBBF8\uCF54\uAC00 10\uCD08\uB9C8\uB2E4 \uC6B4\uC138\uC885\uC774\uB97C
      \uC120\uD0DD\uD569\uB2C8\uB2E4. \uC6B4\uC138\uC885\uC774\uB294 \uD589\uC6B4\uC885\uC774,
      \uBD88\uC6B4\uC885\uC774 2\uAC1C\uB85C \uB098\uB258\uBA70, \uC5B4\uB5A4 \uC6B4\uC138\uC885\uC774\uB97C
      \uC120\uD0DD\uD588\uB290\uB0D0\uC5D0 \uB530\uB77C \uB2E4\uB978 \uD6A8\uACFC\uB97C
      \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4. (\uD589\uC6B4\uC885\uC774 \uD655\uB960
      : 50%, \uBD88\uC6B4\uC885\uC774 \uD655\uB960 : 50%)"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655819
    m_Localized: "\uD589\uC6B4\uC885\uC774"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655820
    m_Localized: "\uD589\uC6B4\uC885\uC774\uB294 \uB79C\uB364\uD55C \uC720\uB2DB\uC5D0\uAC8C
      \uC18C\uD658\uB418\uC5B4, 3X3 \uBC94\uC704\uB97C \uD615\uC131\uD569\uB2C8\uB2E4.
      \uBC94\uC704\uB294 3\uCD08\uAC04 \uC9C0\uC18D\uB418\uBA70, \uBC94\uC704 \uC548\uC5D0
      \uC788\uB294 \uC720\uB2DB\uC758 HP\uB97C \uD68C\uBCF5\uC2DC\uD0A4\uACE0 \uC720\uB2DB\uC758
      HP\uB97C 20% \uC99D\uAC00\uC2DC\uD0B5\uB2C8\uB2E4. (\uD68C\uBCF5\uB7C9: POWER\uC758
      20%)"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655821
    m_Localized: "\uBD88\uC6B4\uC885\uC774"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655822
    m_Localized: "\uBD88\uC6B4\uC885\uC774\uB294 \uB79C\uB364\uD55C \uBAAC\uC2A4\uD130\uC5D0\uAC8C
      \uC18C\uD658\uB418\uC5B4, 3X3 \uBC94\uC704\uC5D0 \uB79C\uB364\uD55C \uBD88\uC6B4\uC744
      \uC2DC\uC804\uD569\uB2C8\uB2E4.\n\uBD88\uC6B4_\uB9C8\uADF8\uB9C8 - \uB9C8\uADF8\uB9C8\uB97C
      \uC18C\uD658\uD574 \uBC94\uC704\uB0B4\uC5D0 \uC788\uB294 \uBAAC\uC2A4\uD130\uB4E4\uC744
      3\uCD08\uAC04 \uBD88\uD0DC\uC6CC \uCD1D 450%\uC758 \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4.\n\uBD88\uC6B4_\uBC88\uAC1C
      - \uBC88\uAC1C\uB97C \uB0B4\uB9AC\uCCD0 \uBC94\uC704\uB0B4\uC5D0 \uC788\uB294
      \uBAAC\uC2A4\uD130\uB4E4\uC5D0\uAC8C 500%\uC758 \uD53C\uD574\uB97C \uC785\uD788\uACE0
      2\uCD08\uAC04 \uAE30\uC808\uC2DC\uD0B5\uB2C8\uB2E4.\n\uBD88\uC6B4_\uC820\uB85C\uC2A4
      - \uBC94\uC704 \uB0B4\uC5D0 \uC788\uB294 \uBAAC\uC2A4\uD130 3\uB9C8\uB9AC\uB97C
      \uC989\uC2DC \uCC98\uCE58\uD569\uB2C8\uB2E4. \uBCF4\uC2A4 \uBAAC\uC2A4\uD130\uB294
      \uD574\uB2F9\uB418\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655823
    m_Localized: "\uBC9A\uAF43\uAE38"
    m_Metadata:
      m_Items: []
  - m_Id: 85394320305655824
    m_Localized: "\uC6B4\uC138\uC885\uC774\uAC00 \uC0AC\uB77C\uC9C8 \uB54C \uB9C8\uB2E4,
      3\uCD08\uAC04 \uD574\uB2F9 \uB77C\uC778\uC5D0 \uBC9A\uAF43\uAE38\uC744 \uC0DD\uC131\uD569\uB2C8\uB2E4.
      \uBC9A\uAF43\uAE38\uC744 \uBC1F\uACE0 \uC788\uB294 \uC720\uB2DB\uC740 POWER\uC640
      \uACF5\uACA9\uC18D\uB3C4\uAC00 30% \uC99D\uAC00\uD558\uBA70, \uBAAC\uC2A4\uD130\uB4E4\uC740
      \uCC9C\uCC9C\uD788 \uB4A4\uB85C \uBC00\uB824\uB0A9\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
