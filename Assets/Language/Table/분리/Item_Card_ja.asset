    m_Localized: "\u30D5\u30A3\u30FC\u30EB\u30C9\u306B\u30B5\u30DD\u30FC\u30BF\u30E6\u30CB\u30C3\u30C8\u304C\u5B58\u5728\u3059\u308B\u5834\u5408\u3001\u5168\u3066\u306E\u30E6\u30CB\u30C3\u30C8\u304C\u5FA9\u6D3B\u80FD\u529B\u3092\u5F97\u307E\u3059\u3002\u5FA9\u6D3B\u3057\u305F\u30E6\u30CB\u30C3\u30C8\u306F\u30015\u79D2\u9593\u653B\u6483\u901F\u5EA6\u304C50%\u5897\u52A0\u3059\u308B\u30D0\u30D5\u3092\u5F97\u307E\u3059\uFF08\u30AF\u30FC\u30EB\u30BF\u30A4\u30E070\u79D2\uFF09\u3002"
