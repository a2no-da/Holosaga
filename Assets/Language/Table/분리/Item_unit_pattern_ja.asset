  - m_Id: 23204322974601216
    m_Localized: "\u30EB\u30FC\u30CA\u304C\u5F8C\u308D3\u5217\u306E\u30E9\u30F3\u30C0\u30E0\u306A\u30BF\u30A4\u30EB\u306B\u30C7\u30B6\u30FC\u30C8\u3092\u53EC\u559A\u3057\u307E\u3059\u3002\u30E6\u30CB\u30C3\u30C8\u304C\u30C7\u30B6\u30FC\u30C8\u3092\u53D6\u5F97\u3059\u308B\u3068\u3001\u305D\u306E\u30C7\u30B6\u30FC\u30C8\u306E\u7A2E\u985E\u306B\u5FDC\u3058\u3066\u3055\u307E\u3056\u307E\u306A\u30D0\u30D5\u3092\u5F97\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002\n-
      \u30DE\u30AB\u30ED\u30F3: \u56DE\u5FA9\u52B9\u679C(\u30EB\u30FC\u30CA\u306EPOWER\u306E100%)\u306B\u52A0\u3048\u3001\u30E6\u30CB\u30C3\u30C8\u306EPOWER\u30925\u79D2\u959350%\u5897\u52A0\u3055\u305B\u307E\u3059\u3002\n-
      \u30C1\u30E7\u30B3\u30EC\u30FC\u30C8: \u56DE\u5FA9\u52B9\u679C(\u30EB\u30FC\u30CA\u306EPOWER\u306E100%)\u306B\u52A0\u3048\u3001\u30E6\u30CB\u30C3\u30C8\u306E\u653B\u6483\u901F\u5EA6\u30925\u79D2\u959350%\u5897\u52A0\u3055\u305B\u307E\u3059\u3002\n-
      \u30B8\u30F3\u30B8\u30E3\u30FC\u30DE\u30F3: \u56DE\u5FA9\u52B9\u679C(\u30EB\u30FC\u30CA\u306EPOWER\u306E100%)\u306B\u52A0\u3048\u3001\u30E6\u30CB\u30C3\u30C8\u306EHP\u30925\u79D2\u959350%\u5897\u52A0\u3055\u305B\u307E\u3059\u3002"
