  - m_Id: 23204322974601220
    m_Localized: "\u30EB\u30FC\u30CA\u306F10\u756A\u76EE\u306E\u30C7\u30B6\u30FC\u30C8\u3068\u3057\u3066\u300C\u9B54\u6CD5\u30AD\u30E3\u30F3\u30C7\u30A3\u300D\u3092\u53EC\u559A\u3067\u304D\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3059\u3002\u9B54\u6CD5\u30AD\u30E3\u30F3\u30C7\u30A3\u306E\u52B9\u679C\u306F\u3001\u3069\u306E\u30E6\u30CB\u30C3\u30C8\u304C\u53D6\u5F97\u3059\u308B\u304B\u306B\u3088\u3063\u3066\u5909\u308F\u308A\u307E\u3059\u3002\n-
      \u30EB\u30FC\u30CA\u4EE5\u5916\u306E\u30E6\u30CB\u30C3\u30C8\u304C\u53D6\u5F97\u3057\u305F\u5834\u5408:
      \u30EB\u30FC\u30CA\u3092\u9664\u304F\u3059\u3079\u3066\u306E\u30E6\u30CB\u30C3\u30C8\u306EPOWER\u3001\u653B\u6483\u901F\u5EA6\u3001HP\u304C7\u79D2\u959350%\u5897\u52A0\u3057\u307E\u3059\u3002\n-
      \u30EB\u30FC\u30CA\u304C\u53D6\u5F97\u3057\u305F\u5834\u5408: \u30EB\u30FC\u30CA\u304C\u4E0A\u8A18\u306E\u30D0\u30D5\u52B9\u679C\u3068\u5171\u306B\u300C\u30EB\u30CA\u30BF\u30A4\u30E0\u300D\u306B\u7A81\u5165\u3057\u307E\u3059\u3002\u30EB\u30FC\u30CA\u30BF\u30A4\u30E0\u306B\u7A81\u5165\u3059\u308B\u3068\u3001\u30E9\u30F3\u30C0\u30E0\u306A10\u30DE\u30B9\u306B\u30EB\u30FC\u30CA\u30A4\u30C8\u3092\u53EC\u559A\u3057\u3001\u6301\u7D9A\u6642\u9593\u4E2D\u306F\u57FA\u672C\u30D1\u30BF\u30FC\u30F3\u304C\u300C\u52A9\u3051\u3066\u3001\u30EB\u30FC\u30CA\u30A4\u30C8\uFF01\u300D\u306B\u7F6E\u304D\u63DB\u3048\u3089\u308C\u307E\u3059\u3002"
