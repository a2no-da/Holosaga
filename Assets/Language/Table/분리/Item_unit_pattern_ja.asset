  - m_Id: 3405470197321729
    m_Localized: "\u30AB\u30EA\u30AA\u30DA\u304C\u30D5\u30A3\u30FC\u30EB\u30C9\u306B\u3044\u308B\u5834\u5408,
      \u30E2\u30F3\u30B9\u30BF\u30FC\u304C\u5012\u308C\u308B\u30685%\u306E\u78BA\u7387\u3067\u9B42\u3092\u7372\u5F97\u3057\u307E\u3059\u3002\u4E00\u5B9A\u6570\u306E\u9B42\u3092\u96C6\u3081\u308B\u3054\u3068\u306B\u3001\u305D\u306E\u30B2\u30FC\u30E0\u4E2D\u30AB\u30EA\u30AA\u30DA\u306EPOWER\u304C\u6C38\u7D9A\u7684\u306B\u5897\u52A0\u3057\u307E\u3059(\u9B4210\u500B\u3054\u3068\u306BPOWER\u304C4\u5897\u52A0)\u3002\n\u30DC\u30B9\u3092\u5012\u3059\u3068100%\u306E\u78BA\u7387\u3067\u5F37\u5316\u3055\u308C\u305F\u9B42\u3092\u7372\u5F97\u3067\u304D,
      \u5F37\u5316\u3055\u308C\u305F\u9B42\u306F\u901A\u5E38\u306E\u9B4250\u500B\u5206\u306E\u30B9\u30BF\u30C3\u30AF\u3092\u63D0\u4F9B\u3057\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
