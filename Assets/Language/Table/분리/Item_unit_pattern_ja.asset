    m_Localized: "\u30EF\u30C8\u30BD\u30F3\u304C\u81EA\u5206\u306E\u7279\u5225\u306A\u6642\u8A08\u3067\u6642\u9593\u3092\u52A0\u901F\u3055\u305B\u3001\u653B\u6483\u901F\u5EA6\u309215\u79D2\u959340%\u901F\u304F\u3057\u307E\u3059\u3002
      \u30D1\u30BF\u30FC\u30F3\u6642\u306B\u6B7B\u4EA1\u3057\u305F\u30E6\u30CB\u30C3\u30C8\u304C\u3042\u308B\u5834\u5408\u306F\u3001\u30E9\u30F3\u30C0\u30E0\u306A\u30EC\u30B9\u30DD\u30F3\u30DD\u30A4\u30F3\u30C8\u30921\u3064\u9078\u629E\u3057\u3066\u6B7B\u4EA1\u5F85\u3061\u6642\u9593\u3092\u534A\u5206\u306B\u6E1B\u3089\u3057\u307E\u3059(\u30AF\u30FC\u30EB\u30BF\u30A4\u30E020\u79D2)\u3002"
