  - m_Id: 23204322974601218
    m_Localized: "\u30EB\u30FC\u30CA\u30A4\u30C8\u304C\u30EB\u30FC\u30CA\u306E\u547C\u3073\u304B\u3051\u306B\u5FDC\u3058\u3066\u3001\u30EB\u30FC\u30CA\u3092\u5B88\u308B\u305F\u3081\u306B\u98DB\u3093\u3067\u304D\u307E\u3059\u3002\u30EB\u30FC\u30CA\u30A4\u30C8\u306F\u6700\u521D\u306B\u3076\u3064\u304B\u3063\u305F\u30E2\u30F3\u30B9\u30BF\u30FC\u306B50%\u306E\u30C0\u30E1\u30FC\u30B8\u3092\u4E0E\u3048\u3001\u305D\u306E\u30E2\u30F3\u30B9\u30BF\u30FC\u306E\u5F8C\u308D\u306E\u30DE\u30B9\u306B\u7740\u5730\u3057\u307E\u3059\u3002\u305D\u306E\u5F8C\u30012\u56DE\u306B\u308F\u305F\u3063\u3066\u305D\u308C\u305E\u308C60%\u306E\u30C0\u30E1\u30FC\u30B8\u3092\u4E0E\u3048\u3001\u6700\u5F8C\u306E\u653B\u6483\u30673\xD73\u306E\u7BC4\u56F2\u306B60%\u306E\u30C0\u30E1\u30FC\u30B8\u3092\u4E0E\u3048\u3001\u30E2\u30F3\u30B9\u30BF\u30FC\u3092\u6C17\u7D76\u3055\u305B\u3066\u6D88\u3048\u307E\u3059\u3002"
    m_Metadata:
