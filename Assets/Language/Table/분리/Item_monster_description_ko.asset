  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Item_monster_description_ko
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ko
  m_SharedData: {fileID: 11400000, guid: f114cb206c4f92e4fa7cc2c0e1f545a6, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 39751187402752
    m_Localized: "\uC774\uB85C\uD558\uC758 \uC5B8\uC81C\uB4E0\uC9C0 \uBA39\uC744
      \uC218 \uC788\uB294 \uBE44\uC0C1\uC2DD\uB7C9\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39751250317312
    m_Localized: "\uCF54\uC694\uB9AC\uC758 \uC560\uC644 \uCF54\uC694\uD14C \uB85C\uBD07\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39751250317313
    m_Localized: "\uD074\uB85C\uC5D0\uC758 \uC544\uC8FC \uD749\uD3EC\uD55C \uBC94\uACE0\uB798\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39751250317314
    m_Localized: "\uCAC0\uB4DD\uD55C \uC678\uBAA8\uC758 \uC6B0\uBB34\uBB38\uC5B4\uC785\uB2C8\uB2E4.\n\n\uD328\uD134
      1 - \uC804\uBC29\uC73C\uB85C \uAC15\uB825\uD55C \uC5D4\uC824 \uB9C1 \uB808\uC774\uC800\uB97C
      \uBC1C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39751250317315
    m_Localized: "\uC18C\uB77C\uC758 \uB4E0\uB4E0\uD55C \uACF0\uC778\uD615\uC785\uB2C8\uB2E4.\n\n\uD328\uD134
      1 - \uC720\uB2DB\uC744 \uAF2D \uC548\uC544 \uACBD\uC9C1\uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39751250317316
    m_Localized: "\uB9C8\uC2DC\uBA5C\uB85C\uC5D0 \uBFD4\uC744 \uB2EC\uC544 \uB193\uC740
      \uB4EF\uD55C \uC0DD\uBA85\uCCB4\uC785\uB2C8\uB2E4.\n\n\uD328\uD134 1 - \uC601\uD63C
      \uAD6C\uC2AC\uC744 \uC3D8\uC544 \uB370\uBBF8\uC9C0\uB97C \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39751254511616
    m_Localized: "\uBE44\uBC00 \uACB0\uC0AC\uC758 \uACBD\uD638\uC6D0\uC785\uB2C8\uB2E4.\n\n\uD328\uD134
      1 - \uC804\uBC29\uC73C\uB85C \uAC15\uB825\uD55C \uAC80\uD48D\uC744 \uB0A0\uB9BD\uB2C8\uB2E4.\n\uD328\uD134
      2 - \uC900\uBE44\uC790\uC138\uB97C \uCDE8\uD55C \uD6C4 \uC804\uBC29\uC5D0 \uC788\uB294
      \uC720\uB2DB\uC744 \uBCA0\uC5B4 \uACBD\uC9C1\uC2DC\uD0B5\uB2C8\uB2E4. \uBC94\uC704
      \uB0B4\uC5D0 \uC720\uB2DB\uC774 \uC5C6\uB2E4\uBA74 3\uCE78 \uC55E\uC73C\uB85C
      \uC774\uB3D9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39751254511617
    m_Localized: "\uBE44\uBC00 \uACB0\uC0AC\uC758 \uC5F0\uAD6C\uC6D0\uC785\uB2C8\uB2E4.\n\n\uD328\uD134
      1 - \uCF54\uC694\uB9AC\uAC00 \uC804\uBC29\uC5D0 \uBBF8\uB9AC \uB9E4\uC124\uD55C
      \uC9C0\uB8B0 5\uAC1C\uB97C \uD130\uD2B8\uB9BD\uB2C8\uB2E4.\n\uD328\uD134 2
      - \uB79C\uB364\uD55C \uD0C0\uC77C\uC5D0 \uB3C5\uC57D 2\uAC1C\uB97C \uB358\uC9D1\uB2C8\uB2E4.
      \uAC00\uB054 \uC2E4\uC218\uB85C \uC790\uC2E0\uC774 \uC4F0\uB824\uB358 \uD68C\uBCF5\uC57D\uB3C4
      \uAC19\uC774 \uB358\uC9D1\uB2C8\uB2E4.\n\uD328\uD134 3 - \uB79C\uB364\uD55C
      \uC720\uB2DB 1\uBA85\uC744 \uAC70\uB9AC\uC5D0 \uC0C1\uAD00\uC5C6\uC774 \uACBD\uC9C1\uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39751254511618
    m_Localized: "\uBE44\uBC00 \uACB0\uC0AC\uC758 \uCCAD\uC18C\uBD80\uC785\uB2C8\uB2E4.\n\n\uD328\uD134
      1 - \uC804\uBC29\uC5D0 \uB2E8\uAC80 1\uC790\uB8E8\uB97C \uB358\uC9D1\uB2C8\uB2E4.\n\uD328\uD134
      2 - \uD074\uB85C\uC5D0\uAC00 \uC218\uADF8\uB9B0 \uD6C4, \uBE60\uB974\uAC8C
      \uC0AC\uB77C\uC9D1\uB2C8\uB2E4. \uC774 \uD6C4 \uB79C\uB364\uD55C 3\uAC1C \uD589\uC5D0
      '\uC12C\uACA9'\uC744 \uC2DC\uC804\uD569\uB2C8\uB2E4.\n\uD328\uD134 3 - \uD074\uB85C\uC5D0\uAC00
      \uC5B4\uB460\uC18D\uC73C\uB85C \uC0AC\uB77C\uC9D1\uB2C8\uB2E4. \uC774 \uD6C4
      \uB79C\uB364\uD55C \uC720\uB2DB 1\uBA85 \uC55E\uC5D0 \uB098\uD0C0\uB098 \uCE58\uBA85\uC801\uC778
      \uD53C\uD574\uB97C \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 15609584629026816
    m_Localized: "\uAC04\uBAA8\uC758 \uC791\uC740 \uCE5C\uAD6C\uB4E4\uC785\uB2C8\uB2E4.
      \uC0DD\uAE34 \uAC83\uACFC \uB2E4\uB974\uAC8C, \uD3ED\uD0C4 \uC54C\uC744 \uB0B3\uC9C0\uB294
      \uBABB\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 15609584712912896
    m_Localized: "\uBE44\uBC00 \uACB0\uC0AC\uC758 \uAC04\uBD80\uC785\uB2C8\uB2E4.\n\n\uD328\uD134
      1 - \uAC04\uBAA8\uAC00 \uB3C5\uC790\uC801\uC73C\uB85C \uC6C0\uC9C1\uC785\uB2C8\uB2E4.
      \uC77C\uC815 \uC2DC\uAC04\uB9C8\uB2E4 \uC804\uBC29\uC744 \uD5A5\uD574 \uB0A0\uC544\uAC00\uBA70
      \uACBD\uB85C\uC5D0 \uC788\uB294 \uC720\uB2DB\uC5D0\uAC8C \uB370\uBBF8\uC9C0\uB97C
      \uC90D\uB2C8\uB2E4.\n\uD328\uD134 2 - \uB8E8\uC774\uAC00 \uC804\uBC29\uC5D0
      '\uB9C8\uBC95 \uD30C\uB3D9'\uC744 \uC2DC\uC804\uD569\uB2C8\uB2E4. \uC774 \uD6C4,
      '\uB9C8\uBC95 \uAD6C\uCCB4'\uB97C \uC2ED\uC790 \uBC29\uD5A5\uC73C\uB85C \uB0A0\uB9AC\uACE0,
      \uB2E4\uC2DC \uD55C\uBC88 x\uC790 \uBC29\uD5A5\uC73C\uB85C \uB0A0\uB9BD\uB2C8\uB2E4.\n\uD328\uD134
      3 - \uB8E8\uC774\uAC00 \uB79C\uB364\uD55C \uC720\uB2DB\uC744 \uC9C0\uC815\uD558\uACE0
      '\uC218\uD608'\uC744 \uC2DC\uC804\uD569\uB2C8\uB2E4. \uB300\uC0C1\uC774 \uB41C
      \uC720\uB2DB\uC740 \uD53C\uD574\uB97C \uC785\uACE0 '\uD54F\uBC29\uC6B8' \uC624\uBE0C\uC81D\uD2B8\uB97C
      \uB5A8\uC5B4\uD2B8\uB9BD\uB2C8\uB2E4. '\uD54F\uBC29\uC6B8'\uC740 \uAC19\uC740
      \uD0C0\uC77C\uC5D0 \uC788\uB294 \uBAAC\uC2A4\uD130 \uB610\uB294 \uC720\uB2DB\uC744
      \uD68C\uBCF5\uC2DC\uD0A4\uACE0 \uC0AC\uB77C\uC9D1\uB2C8\uB2E4.\n\uD328\uD134
      4 - \uB8E8\uC774\uAC00 \uC548\uC804\uC9C0\uB300\uB97C \uC81C\uC678\uD55C \uBAA8\uB4E0
      \uD0C0\uC77C\uC5D0 '\uB9C8\uBC95 \uD3ED\uBC1C'\uC744 \uC2DC\uC804\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 35904632197189632
    m_Localized: "\uBE44\uBC00 \uACB0\uC0AC\uB97C \uCC3D\uC2DC\uD55C \uCD1D\uC218\uC785\uB2C8\uB2E4.\n\n\uB77C\uD50C\uB77C\uC2A4\uB294
      \uD398\uC774\uC988\uB9C8\uB2E4 3\uAC1C\uC758 \uD328\uD134\uC744 \uB79C\uB364\uD558\uAC8C
      \uC2DC\uC804\uD569\uB2C8\uB2E4. \uD398\uC774\uC988\uAC00 \uB05D\uB09C \uD6C4,
      \uB77C\uD50C\uB77C\uC2A4\uB294 \uADF8\uB85C\uAE30 \uC0C1\uD0DC\uC5D0 \uBE60\uC9D1\uB2C8\uB2E4.
      \n\uD398\uC774\uC988 \uC9C4\uD589\uC911\uC77C\uB550 \uB77C\uD50C\uB77C\uC2A4\uB294
      \uC804\uCCB4 \uD53C\uD574\uC758 30%\uB9CC \uC785\uC73C\uBA70, \uADF8\uB85C\uAE30
      \uC0C1\uD0DC\uC77C \uB550 150%\uC758 \uD53C\uD574\uB97C \uC785\uC2B5\uB2C8\uB2E4.\n\uC720\uB2DB\uC774
      \uB9AC\uD0C0\uC774\uC5B4 \uD560 \uB54C \uB9C8\uB2E4, \uB77C\uD50C\uB77C\uC2A4\uC758
      \uB370\uC2A4 \uCE74\uC6B4\uD2B8\uAC00 1 \uC99D\uAC00\uD569\uB2C8\uB2E4. \uADF8\uB85C\uAE30\uAC00
      \uB05D\uB09C \uD6C4, \uB77C\uD50C\uB77C\uC2A4\uB294 \uB370\uC2A4 \uCE74\uC6B4\uD2B8
      X 30\uC5D0 \uD574\uB2F9\uD558\uB294 \uD53C\uD574\uB97C \uBA54\uC778HP\uC5D0
      \uC9C1\uC811 \uAC00\uD569\uB2C8\uB2E4.\n\n\uD328\uD134 1 - \uC77C\uC815\uC2DC\uAC04\uB9C8\uB2E4
      \uB77C\uD50C\uB77C\uC2A4\uAC00 \uB79C\uB364\uD55C \uC720\uB2DB\uC744 \uC9C0\uC815\uD558\uACE0,
      '\uCC28\uC6D0 \uD30C\uD3B8'\uC744 \uC18C\uD658\uD569\uB2C8\uB2E4. \uCC28\uC6D0
      \uD30C\uD3B8\uC740 10\uCD08\uAC00 \uC9C0\uB098\uBA74 \uD130\uC838 \uB300\uC0C1
      \uC720\uB2DB\uC5D0\uAC8C \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4. \uCC28\uC6D0
      \uD30C\uD3B8\uC740 \uD3ED\uBC1C\uD558\uAE30 \uC804 \uC544\uAD70 \uC720\uB2DB\uC774
      \uB300\uC2E0 \uD30C\uAD34\uD574\uC904 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\uD328\uD134
      2 - \uB77C\uD50C\uB77C\uC2A4\uAC00 '\uD30C\uBA78 \uB808\uC774\uC800'\uB97C
      \uBAA8\uB4E0 \uC5F4\uC5D0 \uC2DC\uC804\uD569\uB2C8\uB2E4. \n\uD328\uD134 3
      - \uB77C\uD50C\uB77C\uC2A4\uAC00 \uC720\uB2DB \uC218\uC5D0 \uB9DE\uCDB0 '\uC21C\uBC88
      \uD0C0\uC77C'\uC744 \uC18C\uD658\uD569\uB2C8\uB2E4. \uC77C\uC815 \uC2DC\uAC04
      \uD6C4, \uC790\uC2E0\uC758 \uC21C\uBC88\uC5D0 \uD574\uB2F9\uD558\uC9C0 \uC54A\uB294
      \uD0C0\uC77C\uC5D0 \uC788\uB294 \uC720\uB2DB\uC744 \uCC98\uCE58\uD569\uB2C8\uB2E4.
      \uC774 \uD328\uD134\uC740 3\uD68C \uBC18\uBCF5\uB429\uB2C8\uB2E4.\n\uD328\uD134
      4 - \uB77C\uD50C\uB77C\uC2A4\uAC00 \uC720\uB2DB\uB4E4\uC744 \uCD94\uC801\uD558\uB294
      '\uBE14\uB799\uD640'\uC744 \uC18C\uD658\uD569\uB2C8\uB2E4. \uBE14\uB799\uD640\uC740
      \uCD5C\uC18C 1%\uC5D0\uC11C 100%\uC5D0 \uD574\uB2F9\uD558\uB294 \uB370\uBBF8\uC9C0\uB97C
      \uB79C\uB364\uD558\uAC8C \uC785\uD799\uB2C8\uB2E4. \n\uD328\uD134 5 - \uB77C\uD50C\uB77C\uC2A4\uAC00
      \uBAA8\uB4E0 \uD0C0\uC77C\uC5D0 '\uB300\uADDC\uBAA8 \uCC28\uC6D0 \uBD95\uAD34'\uB97C
      \uC2DC\uC804\uD569\uB2C8\uB2E4.\n\uD328\uD134 6 - \uB77C\uD50C\uB77C\uC2A4\uAC00
      3\uBC88\uC5D0 \uAC78\uCCD0 '\uB9C8\uB825\uC758 \uC190'\uC744 \uC2DC\uC804\uD569\uB2C8\uB2E4.
      \uC774 \uD6C4, X\uC790 \uD615\uD0DC\uC758 '\uD30C\uBA78 \uB808\uC774\uC800'\uB97C
      \uB0A0\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50764120959979520
    m_Localized: "\uBBF8\uCF54\uC758 \uC2E0\uC218\uC785\uB2C8\uB2E4. \uAF2C\uB9AC\uB294
      \uC660\uC9C0 \uBAA8\uB974\uAC8C \uCEE4\uB2E4\uB798\uC9C4 \uBAB8\uC5D0 \uAC00\uB824\uC838
      \uBCF4\uC774\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 76447203864317952
    m_Localized: "\uB77C\uD50C\uB77C\uC2A4\uC758 \uC624\uB79C \uCE5C\uAD6C \uCE74\uB77C\uC2A4\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 76447203906260992
    m_Localized: "\uC721\uAC01\uC131\uC758 \uD540\uC744 \uBA38\uB9AC\uC5D0 \uB2E8
      \uB6B1\uB6B1\uD55C \uACE0\uC591\uC774\uC785\uB2C8\uB2E4.\n\n\uD328\uD134 1
      - \uB79C\uB364\uD55C \uD0C0\uC77C\uC5D0 '\uBC88\uAC1C \uB9C8\uBC95'\uC744 \uC2DC\uC804\uD558\uC5EC
      \uD53C\uD574\uB97C \uC785\uD799\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 76447203906260993
    m_Localized: "\uB85C\uBCF4\uCF54\uC758 \uC791\uC740 \uAC74\uC804\uC9C0 \uB85C\uBD07\uC785\uB2C8\uB2E4.\n\n\uD328\uD134
      1 - \uC804\uBC29 2\uD0C0\uC77C \uC55E\uC73C\uB85C \uC21C\uAC04\uC774\uB3D9
      \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
