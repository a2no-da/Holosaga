  - m_Id: 15609584712912896
    m_Localized: "\u3010\u79D8\u5BC6\u7D50\u793EholoX\u3011\u306E\u5E79\u90E8\u3067\u3059\u3002\n\n\u30D1\u30BF\u30FC\u30F3
