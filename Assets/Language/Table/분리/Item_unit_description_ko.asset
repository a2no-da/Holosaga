  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Item_unit_description_ko
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ko
  m_SharedData: {fileID: 11400000, guid: 6f012bfbe50251644b1d9879f6e54754, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 42402130137088
    m_Localized: "\uB3C8\uC744 \uC88B\uC544\uD558\uAE30\uC5D0, \uC5B8\uC820\uAC00
      \uD574\uC801\uC774 \uB418\uC5B4\uC11C \uBCF4\uBB3C\uC744 \uCC3E\uC544 \uB5A0\uB098\uAE30
      \uC704\uD55C \uD574\uC801\uC120\uC744 \uC0AC\uB294 \uAC83\uC774 \uBAA9\uD45C\uC778
      \uC120\uC7A5.\n\n\uB9C8\uB9B0\uC740 \uAC00\uC7A5 \uBCF4\uD3B8\uC801\uC778 \uC131\uB2A5\uC758
      \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uAE34 \uC0AC\uAC70\uB9AC\uB97C
      \uAC00\uC9C0\uACE0 \uC788\uC9C0\uB9CC HP\uAC00 \uB0AE\uAE30\uC5D0, \uD6C4\uBC29\uC5D0
      \uBC30\uCE58\uD558\uB294 \uAC83\uC744 \uCD94\uCC9C\uB4DC\uB9BD\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uD1B5\uD574 \uBC1C\uC0AC\uD558\uB294
      \uD0C4\uC758 \uAC1C\uC218\uB97C \uB298\uB9B4 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 42402184663040
    m_Localized: "\uB2F9\uADFC\uC744 \uAC01\uBCC4\uD788 \uC0AC\uB791\uD558\uB294
      \uD1A0\uB07C\uADC0 \uC18C\uB140. \uC678\uB85C\uC6C0\uC744 \uC798 \uD0C4\uB2E4.\n\n\uD398\uCF54\uB77C\uB294
      \uD68C\uBCF5\uACFC \uBC84\uD504 \uD6A8\uACFC\uC5D0 \uD2B9\uD654\uB41C \uC11C\uD3EC\uD130
      \uC720\uB2DB\uC785\uB2C8\uB2E4. HP\uAC00 \uB0AE\uACE0, \uACF5\uACA9 \uB2A5\uB825\uC774
      \uC804\uBB34\uD55C \uB300\uC2E0 \uD30C\uD2F0\uC6D0\uB4E4\uC758 HP \uAD00\uB9AC
      \uB2A5\uB825\uC774 \uB6F0\uC5B4\uB0A9\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
      \uB9C8\uCE58\uBA74 \uD68C\uBCF5 \uB2A5\uB825\uACFC \uD568\uAED8 \uBC84\uD504
      \uB2A5\uB825\uB3C4 \uAC00\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 42402184663041
    m_Localized: "\uC778\uAC04\uACFC \uC5D8\uD504\uC758 \uD63C\uD608\uC778 \uD558\uD504\uC5D8\uD504.
      \uD3C9\uC18C \uC801\uB2F9\uD788 \uC990\uAC81\uAC8C \uC9C0\uB0B4\uACE0 \uC788\uB2E4.
      \n\n\uD6C4\uB808\uC544\uB294 \uB77C\uC778 \uD074\uB9AC\uC5B4\uC5D0 \uD2B9\uD654\uB41C
      \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uAE34 \uC0AC\uAC70\uB9AC\uB97C
      \uAC00\uC9C0\uACE0 \uC788\uC9C0\uB9CC HP\uAC00 \uB0AE\uAE30\uC5D0, \uD6C4\uBC29\uC5D0
      \uBC30\uCE58\uD558\uB294 \uAC83\uC744 \uCD94\uCC9C\uB4DC\uB9BD\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uD1B5\uD574 \uB354\uC6B1 \uB113\uC740
      \uBC94\uC704\uC758 \uACF5\uACA9\uC744 \uAC00\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 42402184663042
    m_Localized: "\uB290\uAE0B\uD55C \uBAA8\uC2B5\uACFC \uB2EC\uB9AC, \uBB50\uB4E0\uC9C0
      \uADFC\uB825\uC73C\uB85C \uD574\uACB0\uD558\uB824\uACE0 \uD558\uB294 \uC704\uD5D8\uD55C
      \uBA74\uC744 \uAC00\uC9C4 \uB1CC\uAE4C\uC9C0 \uADFC\uC721\uC778 \uC5EC\uAE30\uC0AC.\n\n\uB178\uC5D8\uC740
      \uCCB4\uB825\uC774 \uB9CE\uACE0, \uB370\uBBF8\uC9C0\uAC00 \uB192\uC740 \uB300\uC2E0
      \uB290\uB9B0 \uACF5\uACA9\uC18D\uB3C4\uB97C \uAC00\uC9C4 \uBC94\uC704\uACF5\uACA9
      \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC804\uBC29\uC5D0 \uBC30\uCE58\uD558\uC5EC
      \uC6D0\uAC70\uB9AC \uC720\uB2DB\uC758 \uBC14\uB9AC\uAC8C\uC774\uD2B8 \uC5ED\uD560\uC744
      \uC2DC\uD0A4\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
      \uD1B5\uD574 \uBAB9\uBAB0\uC774, \uC2A4\uD134 \uB4F1 \uBAAC\uC2A4\uD130\uC758
      \uD589\uB3D9\uC744 \uC81C\uC57D\uD558\uB294 \uB2A5\uB825\uC744 \uAC00\uC9C8
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 42402184663043
    m_Localized: "\uD574\uC800\uC5D0 \uB530\uBD84\uD568\uC744 \uB290\uB07C\uACE0
      \uC778\uAC04 \uC138\uC0C1\uC5D0\uC11C \uC0B4\uACE0 \uC788\uB294, \uC783\uC5B4\uBC84\uB9B0
      \uB3C4\uC2DC \uC544\uD2C0\uB780\uD2F0\uC2A4\uC758 \uD6C4\uC608.\n\n\uAD6C\uB77C\uB294
      \uC900\uC218\uD55C \uBC94\uC704\uC640 \uB370\uBBF8\uC9C0, HP\uB97C \uAC00\uC9C4
      \uBC38\uB7F0\uC2A4 \uD615 \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4.
      \uCD5C\uB300\uD55C \uB9CE\uC774 \uC6C0\uC9C1\uC774\uBA70 \uB2E4\uB978 \uB77C\uC778\uC744
      \uB3D5\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
      \uD1B5\uD574 \uB354\uC6B1 \uB113\uC740 \uBC94\uC704\uC640 \uC911\uCCA9 \uB370\uBBF8\uC9C0\uB97C
      \uAC00\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 42402184663044
    m_Localized: "\uB3C4\uC2DC\uC758 \uBE75\uC9D1\uC5D0\uC11C \uAC00\uAC8C\uB97C
      \uC9C0\uD0A4\uB294 \uAC15\uC544\uC9C0. \uAC8C\uC784\uC744 \uC88B\uC544\uD558\uBA70,
      \uBCF5\uC2F1\uC744 \uC798\uD55C\uB2E4.\n\n\uCF54\uB85C\uB124\uB294 \uB6F0\uC5B4\uB09C
      \uC9D1\uC911 \uACF5\uACA9 \uB2A5\uB825\uC744 \uC9C0\uB2CC \uB300\uC2E0 \uC881\uC740
      \uC0AC\uAC70\uB9AC\uB97C \uAC00\uC9C4 \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4.
      \uBAAC\uC2A4\uD130\uC5D0 \uD070 \uD53C\uD574\uB97C \uC904 \uC218 \uC788\uB294
      \uD55C\uD3B8, \uC0AC\uAC70\uB9AC\uAC00 \uAC00\uAE5D\uAE30\uC5D0 \uBAAC\uC2A4\uD130
      \uD328\uD134\uC5D0 \uC9C1\uACA9\uB2F9\uD560 \uC704\uD5D8\uB3C4 \uD568\uAED8
      \uAC00\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
      \uD1B5\uD574 \uB370\uBBF8\uC9C0\uB97C \uB354\uC6B1 \uB354 \uAC15\uD654\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 42402184663045
    m_Localized: "\uB178\uB798\uB97C \uC88B\uC544\uD558\uC5EC \uB9E4\uBC88 \uB178\uB798
      \uC601\uC0C1\uC744 \uD22C\uACE0\uD558\uB294 \uC591 \uC18C\uB140. \uC5B8\uC820\uAC00
      \uBB34\uB3C4\uAD00\uC5D0 \uC11C\uB294 \uAC83\uC744 \uBAA9\uD45C\uB85C \uD558\uACE0
      \uC788\uB2E4. \n\n\uC640\uD0C0\uBA54\uB294 \uD22C\uC0AC\uCCB4 \uC720\uB2DB
      \uC9C0\uC6D0\uC5D0 \uD2B9\uD654\uB41C \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC785\uB2C8\uB2E4.
      \uB418\uB3C4\uB85D \uC720\uB2DB\uC774 \uB9CE\uC740 \uB77C\uC778\uC5D0 \uD568\uAED8
      \uBC30\uCE58\uD558\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
      \uD1B5\uD574 \uC6D0\uAC70\uB9AC \uC720\uB2DB\uB4E4\uC758 \uBC14\uB9AC\uAC8C\uC774\uD2B8\uB97C
      \uC9C0\uC6D0\uD574 \uC904 \uC218 \uC788\uC73C\uBA70, \uC801\uC744 \uB290\uB9AC\uAC8C
      \uB9CC\uB4E4\uC5B4 \uC720\uB2DB\uC5D0\uAC8C \uC811\uADFC\uD558\uB294 \uAC83\uC744
      \uB2A6\uCD9C \uC218 \uC788\uC2B5\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 42402188857344
    m_Localized: "\uD65C\uAE30\uCC2C \uC131\uACA9\uC758 \uD1B0\uBCF4\uC774. e-sports\uBD80\uC640
      \uC885\uD569 \uACA9\uD22C\uAE30\uBD80\uC758 \uB9E4\uB2C8\uC800\uB97C \uD558\uACE0
      \uC788\uB2E4.\n\n\uC2A4\uBC14\uB8E8\uB294 \uAE34 \uC0AC\uAC70\uB9AC\uC640 \uB6F0\uC5B4\uB09C
      \uBAAC\uC2A4\uD130 \uACAC\uC7AC \uB2A5\uB825\uC744 \uAC00\uC9C4 \uBC94\uC704\uACF5\uACA9
      \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC2A4\uBC14\uB8E8\uC758 \uD328\uD134\uC744
      \uC801\uC808\uD788 \uD65C\uC6A9\uD558\uBA74, \uAC00\uD558\uB294 \uB370\uBBF8\uC9C0\uAC00
      \uC801\uC5B4\uC9C0\uB294 \uB300\uC2E0 \uBAAC\uC2A4\uD130\uB97C \uD06C\uAC8C
      \uBC00\uCCD0\uB0B4\uC5B4 \uC804\uC9C4\uB825\uC744 \uB2A6\uCD9C \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uD1B5\uD574 \uAC00\uD558\uB294 \uD798\uC744
      \uB354\uC6B1 \uB298\uB9B4 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 42402188857345
    m_Localized: "\uD640\uB85C\uB77C\uC774\uBE0C\uC5D0 \uAD00\uD55C \uC774\uC0C1\uD55C
      \uC18C\uBB38\uC744 \uB4E3\uACE0 \uC870\uC0AC\uB97C \uD558\uB358 \uC911, \uADF8
      \uC790\uC2E0\uB3C4 \uD640\uB85C\uB77C\uC774\uBE0C\uC5D0 \uD569\uB958\uD558\uAC8C
      \uB41C \uD0D0\uC815.\n\n\uC544\uBA5C\uB9AC\uC544\uB294 \uBC38\uB7F0\uC2A4\uD615
      \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC900\uC218\uD55C \uB77C\uC778
      \uD074\uB9AC\uC5B4 \uB2A5\uB825\uC744 \uAC00\uC9C0\uACE0 \uC788\uC74C\uACFC
      \uB3D9\uC2DC\uC5D0, \uB2E8\uC77C \uBAAC\uC2A4\uD130\uC5D0\uAC8C \uD2B9\uD788
      \uB354 \uAC15\uB825\uD55C \uD654\uB825\uC744 \uAC00\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4.
      \uC0AC\uB9DD\uD55C \uC720\uB2DB\uC774 \uC788\uB2E4\uBA74, \uD574\uB2F9 \uC0AC\uB9DD
      \uC720\uB2DB\uC774 \uB354 \uBE68\uB9AC \uBD80\uD65C\uD560 \uC218 \uC788\uB3C4\uB85D
      \uB3D5\uAE30\uB3C4 \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 21764844011622400
    m_Localized: "\uADF8\uB9BC \uB9AC\uD37C(Grim reaper)\uC758 \uC81C1\uC81C\uC790.
      \uC758\uB8CC\uAC00 \uBC1C\uB2EC\uD55C \uD604\uB300\uC5D0\uB294 \uC0AC\uC2E0\uC73C\uB85C\uC11C
      \uD65C\uC57D\uD558\uB294 \uACBD\uC6B0\uB294 \uAC70\uC758 \uC5C6\uACE0, \uB300\uC2E0
      VTuber \uD65C\uB3D9\uC73C\uB85C \uD0C0\uC778\uC758 \uC601\uD63C\uC744 \uC218\uD655\uD560
      \uC608\uC815\uC774\uB77C\uB294 \uB4EF \uD558\uB2E4.\n\n\uCE7C\uB9AC\uC624\uD398\uB294
      \uB113\uC740 \uACF5\uACA9\uBC94\uC704\uC640 \uC2DC\uAC04\uC774 \uC9C0\uB0A0\uC218\uB85D
      \uC810\uCC28 \uAC15\uD574\uC9C0\uB294 \uB2A5\uB825\uC744 \uAC00\uC9C4 \uBC94\uC704\uACF5\uACA9
      \uC720\uB2DB\uC785\uB2C8\uB2E4. \uAE30\uBCF8 \uD328\uD134\uC740 \uC18D\uB3C4\uB294
      \uB290\uB9AC\uC9C0\uB9CC \uC138\uB85C \uBC94\uC704\uAC00 \uB113\uAE30\uC5D0,
      \uC790\uC2E0\uC758 \uB77C\uC778 \uBFD0 \uC544\uB2C8\uB77C \uB2E4\uB978 \uB77C\uC778\uAE4C\uC9C0\uB3C4
      \uC27D\uAC8C \uCEE4\uBC84\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30544376055173120
    m_Localized: "\uCC9C\uACC4 \uD559\uC6D0\uC5D0 \uB2E4\uB2C8\uB294 \uCC9C\uC0AC.
      \uCE5C\uD55C \uC0AC\uB78C \uC55E\uC5D0\uC11C\uB294 \uAE30\uC6B4\uC774 \uB118\uCE58\uC9C0\uB9CC,
      \uC0AC\uB78C\uC774 \uB298\uC5B4\uB0A0\uC218\uB85D \uC870\uC6A9\uD574\uC9C0\uB294
      \uC544\uC2F8. \uD734\uC77C\uC5D0\uB294 \uC9D1\uC5D0 \uD2C0\uC5B4\uBC15\uD78C\uB2E4.\n\n\uCE74\uB098\uD0C0\uB294
      \uCC9C\uCC9C\uD788 \uC2A4\uD0DD\uC744 \uC313\uC544 \uAC15\uB825\uD55C \uD55C\uBC29\uC744
      \uB0A0\uB9B4 \uC218 \uC788\uB294 \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4.
      \uCE74\uB098\uD0C0\uAC00 \uC8FD\uC73C\uBA74 \uBAA8\uB4E0 \uC2A4\uD0DD\uC774
      \uC0AC\uB77C\uC9C0\uAE30 \uB54C\uBB38\uC5D0, \uC0DD\uC874\uC5D0 \uC720\uC758\uD558\uBA70
      \uBCF4\uC2A4 \uC2A4\uD14C\uC774\uC9C0\uAE4C\uC9C0 \uC2A4\uD0DD\uC744 \uC720\uC9C0\uD558\uB294
      \uAC83\uC744 \uBAA9\uD45C\uB85C \uD558\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 42810589535768576
    m_Localized: "\uACFC\uC790\uB098\uB77C\uC758 \uACF5\uC8FC\uB2D8. \uC5B4\uB9AC\uAD11\uC7C1\uC774\uC5D0
      \uC0AC\uB78C\uC744 \uC798 \uB530\uB974\uC9C0\uB9CC \uC81C\uBA4B\uB300\uB85C\uC778
      \uBC1C\uC5B8\uC73C\uB85C \uC790\uC8FC \uC9D1\uC0AC\uC5D0\uAC8C \uD63C\uB098\uACE0
      \uC788\uB2E4. \uB2EC \uBAA8\uC591 \uC561\uC138\uC11C\uB9AC\uB294 \uC774\uC138\uACC4
      \uAD6D\uAC00\uC758 \uB9C8\uD06C\uB77C\uB294 \uB4EF \uD558\uB2E4.\n\n\uB8E8\uB098\uB294
      \uC720\uB2DB\uC744 \uD68C\uBCF5\uD558\uACE0 \uBC84\uD504\uB97C \uC8FC\uB294
      \uB2A5\uB825\uC5D0 \uB354\uD574, \uC2A4\uD134\uC5D0 \uD2B9\uD654\uB41C \uC11C\uD3EC\uD130
      \uC720\uB2DB\uC785\uB2C8\uB2E4. \uB2E4\uC591\uD55C \uC885\uB958\uC758 \uB514\uC800\uD2B8\uB97C
      \uC18C\uD658\uD558\uC5EC \uC720\uB2DB\uB4E4\uC5D0\uAC8C \uD68C\uBCF5\uACFC
      \uD568\uAED8 \uB2E4\uC591\uD55C \uBC84\uD504\uB97C \uC904 \uC218\uB3C4 \uC788\uC73C\uBA70,
      \uC77C\uC815 \uC2DC\uAC04\uB9C8\uB2E4 \uB8E8\uB098\uC774\uD2B8\uB97C \uB0B4\uBCF4\uB0B4
      \uBAAC\uC2A4\uD130\uB97C \uAE30\uC808\uC2DC\uCF1C \uD328\uD134\uC744 \uB04A\uC744
      \uC218\uB3C4 \uC788\uC2B5\uB2C8\uB2E4. \uC0C1\uD669\uC5D0 \uB9DE\uCD94\uC5B4
      \uB9C8\uBC95\uCE94\uB514\uB97C \uC5B4\uB5A4 \uC720\uB2DB\uC5D0\uAC8C \uC8FC\uB290\uB0D0\uC5D0
      \uB530\uB77C, \uC720\uB2DB \uC804\uCCB4\uC758 \uB370\uBBF8\uC9C0\uB97C \uAC15\uD654\uD558\uAC70\uB098,
      \uAC15\uB825\uD55C \uB77C\uC778\uD074\uB9AC\uC5B4\uC640 \uD568\uAED8 \uB8E8\uB098
      \uBCF8\uC778\uC758 \uC2A4\uD134 \uB2A5\uB825\uC744 \uB354\uC6B1 \uAC15\uD654\uC2DC\uD0AC\uC218\uB3C4
      \uC788\uC2B5\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 53034328445652992
    m_Localized: "\uBC31\uBC1C \uB3D9\uBB3C\uADC0 \uC624\uD0C0\uCFE0 \uC5EC\uC6B0.
      \uC0AC\uB78C\uB4E4\uACFC \uC774\uC57C\uAE30\uD558\uB294 \uAC83\uC744 \uC88B\uC544\uD574\uC11C
      \uC5B4\uC6B8\uB824\uC8FC\uBA74 \uAE30\uBED0\uD55C\uB2E4. \uB9E4\uC77C \uC990\uAC81\uAC8C
      \uC9C0\uB0B4\uBA74\uC11C \uD1B1 \uC624\uD0C0\uCFE0 \uC544\uC774\uB3CC\uC744
      \uBAA9\uD45C\uB85C \uD558\uACE0 \uC788\uB2E4.\n\n\uD6C4\uBD80\uD0A4\uB294 \uD3C9\uC18C
      \uB2E4\uB978 \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC5D0 \uBE44\uD574 \uC57D\uD55C
      \uB300\uC2E0, \uBCC0\uC2E0\uC744 \uD1B5\uD574 \uB9C9\uAC15\uD55C \uB370\uBBF8\uC9C0
      \uD3EC\uD150\uC15C\uC744 \uBF50\uB0BC \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uAC8C\uC774\uC9C0\uB97C
      \uCD5C\uB300\uD55C \uC798 \uAD00\uB9AC\uD558\uC5EC \uCFE0\uB85C\uCE74\uBBF8
      \uD6C4\uBD80\uD0A4 \uC0C1\uD0DC\uB97C \uC624\uB798 \uC720\uC9C0\uD558\uB294
      \uAC83\uC774 \uAD00\uAC74\uC774\uBA70, \uC774\uB97C \uC704\uD574 \uAC8C\uC774\uC9C0\uB97C
      \uB108\uBB34 \uB0A8\uC6A9\uD558\uC9C0 \uC54A\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 60947205622042624
    m_Localized: "\uC5B4\uC5FF\uD55C \uC545\uB9C8\uAC00 \uB418\uAE30 \uC704\uD55C
      \uC0AC\uD68C \uACF5\uBD80\uB85C\uC11C \uC778\uAC04\uACC4\uB85C \uC628 \uC18C\uC545\uB9C8.
      \uC6D0\uB798\uB294 \uACF5\uBD80\uD574\uC57C \uD558\uB294 \uB54C\uC5D0 \uAC8C\uC784\uC744
      \uC811\uD574\uBC84\uB824, \uD479 \uBE60\uC838\uC788\uB2E4. \uC778\uD130\uB137
      \uBC29\uC1A1\uC774\uB77C\uB294 \uC778\uAC04\uB4E4\uC758 \uCEE4\uBBA4\uB2C8\uCF00\uC774\uC158
      \uD234\uC744 \uBC1C\uACAC\uD574, \uC774\uAC78\uB85C \uACF5\uBD80\uB97C \uC2DC\uB3C4\uD558\uACE0
      \uC788\uB2E4.\n\n\uD1A0\uC640\uB294 \uB2E4\uB978 \uB77C\uC778\uC5D0 \uC788\uB294
      \uBAAC\uC2A4\uD130\uB97C \uB04C\uC5B4\uB2F9\uAE30\uACE0, \uC6D0\uAC70\uB9AC\uC5D0\uC11C
      \uAD00\uD1B5 \uB808\uC774\uC800\uB97C \uBC1C\uC0AC\uD558\uB294 \uB4F1 \uB77C\uC778\uD074\uB9AC\uC5B4\uC5D0
      \uD2B9\uD654\uB41C \uC720\uB2DB\uC785\uB2C8\uB2E4. \uB300\uC2E0 \uACF5\uACA9\uC18D\uB3C4\uAC00
      \uB290\uB9AC\uACE0, \uD654\uB825\uC774 \uB2E4\uC18C \uBD80\uC871\uD558\uC5EC
      \uBCF4\uC2A4 \uBAAC\uC2A4\uD130\uB098 \uCCB4\uB825\uC774 \uB9CE\uC740 \uBAAC\uC2A4\uD130\uB97C
      \uC0C1\uB300\uD560\uB54C\uB294 \uD654\uB825\uC744 \uBCF4\uC870\uD574 \uC904
      \uC720\uB2DB\uACFC \uAC19\uC774 \uC0AC\uC6A9\uD558\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 63396607120871424
    m_Localized: "\uC218\uB9CE\uC740 \uC0AC\uAC74\uB4E4\uC758 \uC99D\uC778\uC73C\uB85C\uC11C
      \uD0DC\uC5B4\uB09C \uBB38\uBA85\uC758 \uC218\uD638\uC790\uC774\uC790, \uBC29\uB791\uD558\uB294
      \uC62C\uBE7C\uBBF8. \uADF8\uB140\uC758 \uB05D\uC5C6\uB294 \uC5EC\uD589\uC5D0\uC11C
      \uACAA\uACE0 \uC78A\uC5B4\uBC84\uB9B0- \uADF8\uB140\uC758 \uC783\uC5B4\uBC84\uB9B0
      \uAE30\uC5B5\uB4E4\uC758 \uD3B8\uAD11\uC774 \uAC00\uB054\uC529 \uD45C\uCD9C\uB418\uAE30\uB294
      \uD558\uC9C0\uB9CC, \uC774\uC81C \uADF8\uB140\uB294 \uD558\uB8E8\uD558\uB8E8\uB97C
      \uC990\uAE30\uB294 \uC0AC\uB791\uC2A4\uB7EC\uC6B4 \uC18C\uB140\uB2E4.\n\n\uBB34\uBA54\uC774\uB294
      \uACF5\uACA9\uC18D\uB3C4\uB97C \uB298\uB824\uC11C, \uB9CE\uC740 \uD22C\uC0AC\uCCB4\uB97C
      \uBC1C\uC0AC\uD558\uB294 \uAC83\uC774 \uAE43\uD138 \uD3ED\uBC1C\uC744 \uB9CE\uC774
      \uC77C\uC73C\uD0AC \uC218 \uC788\uC5B4 \uC720\uB9AC\uD569\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uAC00
      \uBAA8\uB450 \uB05D\uB09C \uBB34\uBA54\uC774\uB294 \uB77C\uC778\uD074\uB9AC\uC5B4
      \uB2A5\uB825\uC744 \uD06C\uAC8C \uAC15\uD654\uC2DC\uD0AC \uC218 \uC788\uC2B5\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 69457262311608320
    m_Localized: "\uC678\uB534 \uBC31\uC740\uC758 \uB300\uC9C0\uC5D0 \uC0AC\uB294
      \uB208\uC758 \uC77C\uC871\uC758 \uC601\uC560. \uD640\uB85C\uB77C\uC774\uBE0C\uC758
      \uBBF8\uC18C\uC640 \uD654\uB824\uD55C \uBC29\uC1A1\uC5D0 \uB9C8\uC74C\uC744
      \uC0AC\uB85C\uC7A1\uD600, \uC9D1\uC744 \uB6F0\uCCD0\uB098\uC654\uB2E4. \uC131\uC2E4\uD558\uC9C0\uB9CC
      \uC138\uC0C1 \uBB3C\uC815\uC744 \uBAA8\uB974\uACE0 \uC5BC\uBE60\uC9C4 \uB370\uAC00
      \uC788\uB2E4.\n\n\uB77C\uBBF8\uB294 \uB113\uC740 \uACF5\uACA9 \uBC94\uC704\uC640
      \uBB34\uC801 \uC2A4\uD0AC\uC744 \uAC16\uCD94\uACE0 \uC788\uC5B4, \uC5B4\uB5A4
      \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uC548\uC815\uC801\uC778 \uD50C\uB808\uC774\uAC00
      \uAC00\uB2A5\uD55C \uC720\uB2DB\uC785\uB2C8\uB2E4. \uD55C \uBC88\uC5D0 \uD070
      \uB370\uBBF8\uC9C0\uB97C \uC8FC\uC9C4 \uC54A\uC9C0\uB9CC, \uC9C0\uC18D\uC801\uC778
      \uD53C\uD574\uB97C \uD1B5\uD574 \uAC15\uB825\uD55C \uC131\uB2A5\uC744 \uBC1C\uD718\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 72075646488514560
    m_Localized: "\uB178\uB798\uC640 \uC544\uC774\uB3CC\uC744 \uAC01\uBCC4\uD788
      \uC0AC\uB791\uD558\uB294 \uBC84\uCE04\uC5BC \uC544\uC774\uB3CC. \uC5B8\uC820\uAC00
      \uBB34\uB3C4\uAD00\uC5D0\uC11C \uB77C\uC774\uBE0C\uB97C \uD558\uB294 \uAC83\uC744
      \uAFC8\uAFB8\uBA70 \uD65C\uB3D9\uD558\uACE0 \uC788\uB2E4.\n\n\uC2A4\uC774\uC138\uC774\uB294
      \uC900\uC218\uD55C \uC0AC\uAC70\uB9AC\uC640 \uBC94\uC704 \uACF5\uACA9\uC744
      \uAC00\uC9C0\uACE0 \uC788\uB294 \uBC38\uB7F0\uC2A4\uD615 \uBC94\uC704\uACF5\uACA9
      \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC561\uD2F0\uBE0C \uD328\uD134\uC744 \uD1B5\uD574
      \uC2A4\uD0DD\uC744 \uC313\uACE0, \uD544\uB4DC\uB97C \uBAA8\uB450 \uC815\uB9AC\uD560
      \uC218 \uC788\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744 \uAC00\uD560 \uC218
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 83419981448450048
    m_Localized: "\uC778\uD130\uB137\uC5D0 \uB098\uD0C0\uB098\uC11C \uC0AC\uB78C\uB4E4\uC744
      \uC774\uAE30\uACE0 \uC790\uC5F0\uC73C\uB85C \uD68C\uADC0\uD560 \uAC83\uC744
      \uC124\uB4DD\uD558\uB294 \uC790\uC5F0\uC758 \uC218\uD638\uC790\uC774\uC790,
      \uB4DC\uB8E8\uC774\uB4DC \uAE30\uB9B0.\n\n\uD30C\uC6B0\uB098\uB294 \uB113\uC740
      \uBC94\uC704\uC758 \uAD11\uC5ED \uD68C\uBCF5\uACFC \uBC84\uD504\uB97C \uAC00\uC9C4
      \uC11C\uD3EC\uD130 \uC720\uB2DB\uC73C\uB85C, \uD30C\uC885\uC744 \uD1B5\uD574
      \uC720\uB2DB\uC758 \uD2B9\uC131\uC5D0 \uB530\uB77C \uB2E4\uC591\uD55C \uBC84\uD504\uB97C
      \uC81C\uACF5\uD574\uC904 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
      \uB9C8\uCE5C \uD30C\uC6B0\uB098\uB294 \uAE09\uC18D\uC131\uC7A5\uC744 \uD1B5\uD574
      \uBAAC\uC2A4\uD130\uC758 \uC9C4\uCD9C\uC744 \uB9C9\uC544\uB0B4\uB294 \uBCBD\uC744
      \uC0DD\uC131\uD560 \uC218 \uC788\uC5B4, \uC6D0\uAC70\uB9AC\uC5D0\uC11C \uBAAC\uC2A4\uD130\uB97C
      \uACF5\uACA9\uD560 \uC218 \uC788\uB294 \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uB4E4\uACFC
      \uC870\uD569\uC774 \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 83419981494587392
    m_Localized: "\uBB34\uB364\uC5D0\uC11C \uB098\uC628 \uC880\uBE44 \uC5EC\uACE0\uC0DD.
      \uC0DD\uC804 \uAE30\uC5B5\uC744 \uC758\uC9C0\uD558\uC5EC \uC9D1\uC5D0 \uB3CC\uC544\uAC14\uC9C0\uB9CC
      \uBAA8\uB974\uB294 \uB77C\uBA58\uC9D1\uC774 \uB418\uC5B4\uC788\uC5C8\uB2E4.\n\n\uC62C\uB9AC\uB294
      \uAE34 \uC0AC\uAC70\uB9AC\uC640 \uD761\uD608 \uB2A5\uB825, \uC18C\uD658\uC218\uB4E4\uC744
      \uD1B5\uD55C \uD0F1\uD0B9 \uB4F1 \uC0DD\uC874\uC5D0 \uD2B9\uD654\uB41C \uBC94\uC704\uACF5\uACA9
      \uC720\uB2DB\uC785\uB2C8\uB2E4. \uCD5C\uB300\uD55C \uC624\uB798 \uC0DD\uC874\uD558\uBA74\uC11C,
      \uBE44\uC11D\uC758 \uAC1C\uC218\uB97C \uCD5C\uB300\uB85C \uC720\uC9C0\uD558\uB294
      \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 84924920100261888
    m_Localized: "\uB4F1\uB300 \uAF2D\uB300\uAE30\uC5D0 \uC0AC\uB294 \uB290\uAE0B\uD55C
      \uC131\uACA9\uC758 \uC18C\uB140. \uC0AC\uC2E4\uC740 \uC9C0\uC5ED\uC5D0\uC11C
      \uAC00\uC7A5 \uD070 \uD798\uC744 \uAC00\uC9C4 \uB808\uC778 \uC0E4\uBA3C\uC758
      \uD608\uD1B5\uC774\uB2E4. \uBE44\uB97C \uC790\uC720\uC790\uC7AC\uB85C \uC870\uC885\uD558\uB294
      \uB2A5\uB825\uC744 \uAC00\uC84C\uC9C0\uB9CC, \uB0A8\uC774 \uC2DC\uCF1C\uC11C
      \uB2A5\uB825\uC744 \uC0AC\uC6A9\uD558\uB294 \uAC74 \uC2EB\uC5B4\uD55C\uB2E4.\n\n\uCF54\uBCF4\uB294
      \uBAAC\uC2A4\uD130\uC758 \uC9C4\uCD9C\uC744 \uBC29\uD574\uD558\uB294 \uB2E4\uC591\uD55C
      cc\uAE30\uB97C \uBCF4\uC720\uD558\uACE0 \uC788\uB294 \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC73C\uB85C,
      \uC870\uC791 \uC5EC\uD558\uC5D0 \uB530\uB77C \uB113\uC740 \uBC94\uC704\uB97C
      \uCEE4\uBC84\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uD655\uC815 \uC2A4\uD134
      \uAE30\uB2A5\uC73C\uB85C \uC778\uD574 \uBCF4\uC2A4 \uACAC\uC81C\uB098 \uD2B9\uC218
      \uBAAC\uC2A4\uD130 \uACAC\uC81C\uC5D0\uB3C4 \uC88B\uC740 \uC720\uB2DB\uC785\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 105000787300028416
    m_Localized: "2017\uB144 9\uC6D4 7\uC77C\uBD80\uD130 \uD65C\uB3D9\uC744 \uC2DC\uC791\uD55C
      \uD640\uB85C\uB77C\uC774\uBE0C \uD504\uB85C\uB355\uC158 \uCD5C\uCD08\uC758
      \uBC84\uCE04\uC5BC \uC544\uC774\uB3CC. \uB178\uB798\uC640 \uD638\uB7EC \uAC8C\uC784\uC744
      \uC88B\uC544\uD558\uACE0, \uD65C\uB3D9 \uCD08\uAE30\uBD80\uD130 \"\uC694\uCF54\uD558\uB9C8
      \uC544\uB808\uB098\uC5D0\uC11C \uB77C\uC774\uBE0C\uB97C \uD558\uB294 \uAC83\"\uC744
      \uAFC8\uAFB8\uACE0 \uC788\uB2E4.\n\n\uC18C\uB77C\uB294 \uBAA8\uB4E0 \uC720\uB2DB\uC744
      \uCF00\uC5B4\uD558\uB294 \uB2A5\uB825\uC740 \uB2E4\uB978 \uC720\uB2DB\uB4E4\uC5D0
      \uBE44\uD574 \uBD80\uC871\uD558\uC9C0\uB9CC, \uB2E8\uC77C \uC720\uB2DB\uC758
      \uC131\uB2A5\uC744 \uD06C\uAC8C \uBCF4\uC870\uD574\uC904 \uC218 \uC788\uB294
      \uC11C\uD3EC\uD130 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC561\uD2F0\uBE0C \uD328\uD134\uC744
      \uD1B5\uD574 \uBAA8\uB4E0 \uC720\uB2DB\uC758 \uC131\uB2A5\uC744 \uAC15\uD654\uC2DC\uD0AC\uC218\uB3C4
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 105000787346165760
    m_Localized: "\uC804\uB1CC \uBC9A\uAF43 \uC2E0\uC0AC\uC758 \uBB34\uB140\uB85C\uC11C
      \uC131\uC2E4\uD558\uAC8C \uC2E0\uC744 \uBAA8\uC154\uC654\uC9C0\uB9CC, \uC2E0\uC758
      \uC2EC\uBD80\uB984\uC744 \uBC1B\uC544 \uC77C\uBCF8\uC5D0 \uBC29\uBB38\uD588\uC744
      \uB54C(\uC2EC\uBD80\uB984\uC744 \uD558\uB358 \uC911) \"\uD1A0\uD0A4\uB178 \uC18C\uB77C\"\uC640
      \uB9CC\uB098 \uB3D9\uACBD\uC744 \uD488\uAC8C \uB418\uC5B4 \uBC84\uCE04\uC5BC
      \uBB34\uB140 \uC544\uC774\uB3CC\uC774 \uB418\uAE30\uB85C \uACB0\uC2EC\uD588\uB2E4.\n\n\uBBF8\uCF54\uB294
      \uC640\uD0C0\uBA54\uC640 \uAC19\uC774 \uC11C\uD3EC\uD130 \uB2A5\uB825\uC744
      \uACB8\uBE44\uD55C \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC9C0\uC18D\uC801\uC73C\uB85C
      \uC6B4\uC138\uC885\uC774\uB97C \uC120\uD0DD\uD558\uC5EC \uC544\uAD70 \uC720\uB2DB\uC744
      \uB3D5\uAC70\uB098 \uBAAC\uC2A4\uD130\uC5D0\uAC8C \uD53C\uD574\uB97C \uC785\uD790
      \uC218 \uC788\uC73C\uBA70, '\uBC9A\uAF43\uAE38'\uC744 \uD1B5\uD574 \uBAAC\uC2A4\uD130\uC758
      \uC9C4\uCD9C\uC744 \uBC29\uD574\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
