  - m_Id: 18106501590126642
    m_Localized: "SHOP\u3067\u306FHOLOMONEY\u3092\u4F7F\u7528\u3057\u3066\u30E6\u30CB\u30C3\u30C8\u3092\u8CFC\u5165\u3057\u3066\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u3059\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002\n\n\u6700\u521D\u304B\u3089\u958B\u3044\u3066\u3044\u308B\u30E6\u30CB\u30C3\u30C8\u3082\u5B58\u5728\u3057\u307E\u3059\u304C\u3001\u30ED\u30C3\u30AF\u3055\u308C\u3066\u3044\u308B\u30E6\u30CB\u30C3\u30C8\u304C\u3042\u308C\u3070\u3001\u305D\u306E\u30E6\u30CB\u30C3\u30C8\u3092HOLOMONEY\u3067\u8CFC\u5165\u3059\u308B\u5FC5\u8981\u304C\u3042\u308A\u307E\u3059\u3002
      \u30E6\u30CB\u30C3\u30C8\u3092\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u3059\u308B\u3068\u3001\u30E6\u30CB\u30C3\u30C8\u304C\u3053\u308C\u307E\u3067\u306B\u4F7F\u7528\u3067\u304D\u306A\u304B\u3063\u305F\u65B0\u3057\u3044\u30D1\u30BF\u30FC\u30F3\u3082\u4F7F\u7528\u3067\u304D\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3059\u3002\n\n\u30E6\u30CB\u30C3\u30C8\u30B9\u30AD\u30F3\u30B7\u30E7\u30C3\u30D7\u3067\u306F\u3001\u30E6\u30CB\u30C3\u30C8\u306E\u30B9\u30AD\u30F3\u3082\u8CFC\u5165\u3057\u3066\u4F7F\u7528\u3067\u304D\u307E\u3059\u3002
      \u9069\u7528\u3057\u305F\u30B9\u30AD\u30F3\u306F\u30A4\u30F3\u30B2\u30FC\u30E0\u306B\u53CD\u6620\u3055\u308C\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126643
    m_Localized: "UNITSELECT \u306B\u3064\u3044\u3066"
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126644
    m_Localized: "\u30B2\u30FC\u30E0\u3092\u958B\u59CB\u3057\u305F\u3089\u3001\u307E\u305A\u30B2\u30FC\u30E0\u5185\u3067\u4F7F\u7528\u3059\u308B\u30E6\u30CB\u30C3\u30C8\u3092\u9078\u3076\u5FC5\u8981\u304C\u3042\u308A\u307E\u3059\u3002
      \n\n\u30E6\u30CB\u30C3\u30C8\u306F\u6700\u59274\u4EBA\u307E\u3067\u9078\u629E\u3067\u304D\u3001\u305D\u308C\u4EE5\u4E0B\u306E\u6570\u5B57\u3082\u53EF\u80FD\u3067\u3059\u3002
      \u3082\u3057\u3042\u306A\u305F\u304C\u6311\u6226\u304C\u597D\u304D\u306A\u3089\u3001\u4EE5\u524D\u3088\u308A\u3082\u5C11\u306A\u3044\u30E6\u30CB\u30C3\u30C8\u3067\u30B2\u30FC\u30E0\u3092\u30AF\u30EA\u30A2\u3057\u3066\u307F\u308B\u306E\u3082\u4E00\u3064\u306E\u697D\u3057\u307F\u8981\u7D20\u306B\u306A\u308B\u304B\u3082\u3057\u308C\u307E\u305B\u3093\u3002\n\n\u30A2\u30A4\u30B3\u30F3\u3092\u901A\u3058\u3066\u73FE\u5728\u306E\u30E6\u30CB\u30C3\u30C8\u306E\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u72B6\u614B\u304C\u3069\u3046\u304B\u3092\u78BA\u8A8D\u3059\u308B\u3053\u3068\u304C\u3067\u304D\u3001\u3067\u304D\u308B\u3060\u3051\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u6570\u5024\u304C\u9AD8\u3044\u30E6\u30CB\u30C3\u30C8\u3092\u9078\u629E\u3059\u308B\u3053\u3068\u3092\u304A\u52E7\u3081\u3057\u307E\u3059\u3002"
