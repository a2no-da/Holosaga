  - m_Id: 18106501590126639
    m_Localized: "\u30E6\u30CB\u30C3\u30C8\u3068COLLECTION\u306B\u3064\u3044\u3066"
    m_Metadata:
      m_Items: []
  - m_Id: 18106501590126640
    m_Localized: "\u30DB\u30ED\u30E9\u30A4\u30D6\u30A2\u30A4\u30C9\u30EB\u3067\u69CB\u6210\u3055\u308C\u305F\u30E6\u30CB\u30C3\u30C8\u306F\u3001\u3053\u306E\u30B2\u30FC\u30E0\u306E\u6838\u5FC3\u30D7\u30EC\u30A4\u8981\u7D20\u3067\u3059\u3002\r\n\r\n\u30E6\u30CB\u30C3\u30C8\u306F\u3001\u81EA\u5206\u304C\u6301\u3063\u3066\u3044\u308B\u30D1\u30BF\u30FC\u30F3\u3092\u5B9F\u884C\u3057\u3066\u30E2\u30F3\u30B9\u30BF\u30FC\u3092\u9632\u304E\u3001\u4FB5\u653B\u3092\u963B\u6B62\u3057\u307E\u3059\u3002
      \u30B7\u30E7\u30C3\u30D7\u3067\u306E\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u306B\u3088\u308A\u3001\u3055\u3089\u306B\u5F37\u304F\u306A\u308B\u53EF\u80FD\u6027\u304C\u3042\u308A\u307E\u3059\u3002\n\nCOLLECTION\u3067\u306F\u3001\u3042\u306A\u305F\u304C\u5F97\u305F\u30E6\u30CB\u30C3\u30C8\u306B\u95A2\u3059\u308B\u60C5\u5831\u3092\u78BA\u8A8D\u3059\u308B\u3053\u3068\u304C\u3067\u304D\u3001\u3042\u306A\u305F\u304C\u30E6\u30CB\u30C3\u30C8\u307E\u305F\u306F\u30E2\u30F3\u30B9\u30BF\u30FC\u306E\u60C5\u5831\u3092\u3069\u308C\u3060\u3051\u96C6\u3081\u305F\u304B\u3092\u77E5\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002
      \u3053\u306E\u60C5\u5831\u306F\u3001\u30E6\u30CB\u30C3\u30C8\u3092\u8CFC\u5165\u3057\u3066\u5F97\u305F\u308A\u3001\u30E2\u30F3\u30B9\u30BF\u30FC\u306B\u906D\u9047\u3057\u305F\u3068\u304D\u306B\u53D6\u5F97\u3067\u304D\u307E\u3059\u3002"
    m_Metadata:
