  - m_Id: 18106501590126638
    m_Localized: "HOLOSAGA\u306F\u8AB0\u3067\u3082\u7C21\u5358\u306B\u697D\u3057\u3081\u308B\u30C7\u30A3\u30D5\u30A7\u30F3\u30B9\u30B2\u30FC\u30E0\u3067\u3059!\n\n\u64CD\u4F5C\u306F\u7C21\u5358\u3067\u3001\u30E2\u30F3\u30B9\u30BF\u30FC\u306E\u30D1\u30BF\u30FC\u30F3\u3082\u305D\u308C\u307B\u3069\u96E3\u3057\u304F\u3042\u308A\u307E\u305B\u3093\u3002\n\n\u597D\u304D\u306A\u30E6\u30CB\u30C3\u30C8\u3092\u9078\u3093\u3067\u81EA\u5206\u3060\u3051\u306E\u7D44\u307F\u5408\u308F\u305B\u3092\u4F5C\u3063\u3066\u30B9\u30C6\u30FC\u30B8\u3092\u30AF\u30EA\u30A2\u3057\u3066\u307F\u3066\u304F\u3060\u3055\u3044!"
