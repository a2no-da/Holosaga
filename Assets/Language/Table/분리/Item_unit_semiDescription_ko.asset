  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Item_unit_semiDescription_ko
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ko
  m_SharedData: {fileID: 11400000, guid: 20b0c408f011b304c8a95e6fb516e471, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 127450714112
    m_Localized: "\uB9C8\uB9B0\uC740 \uAC00\uC7A5 \uBCF4\uD3B8\uC801\uC778 \uC131\uB2A5\uC758
      \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uAE34 \uC0AC\uAC70\uB9AC\uB97C
      \uAC00\uC9C0\uACE0 \uC788\uC9C0\uB9CC HP\uAC00 \uB0AE\uAE30\uC5D0, \uD6C4\uBC29\uC5D0
      \uBC30\uCE58\uD558\uB294 \uAC83\uC744 \uCD94\uCC9C\uB4DC\uB9BD\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uD1B5\uD574 \uBC1C\uC0AC\uD558\uB294
      \uD0C4\uC758 \uAC1C\uC218\uB97C \uB298\uB9B4 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127501045760
    m_Localized: "\uD398\uCF54\uB77C\uB294 \uD68C\uBCF5\uACFC \uBC84\uD504 \uD6A8\uACFC\uC5D0
      \uD2B9\uD654\uB41C \uC11C\uD3EC\uD130 \uC720\uB2DB\uC785\uB2C8\uB2E4. HP\uAC00
      \uB0AE\uACE0, \uACF5\uACA9 \uB2A5\uB825\uC774 \uC804\uBB34\uD55C \uB300\uC2E0
      \uD30C\uD2F0\uC6D0\uB4E4\uC758 HP \uAD00\uB9AC \uB2A5\uB825\uC774 \uB6F0\uC5B4\uB0A9\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uB9C8\uCE58\uBA74 \uD68C\uBCF5 \uB2A5\uB825\uACFC
      \uD568\uAED8 \uBC84\uD504 \uB2A5\uB825\uB3C4 \uAC00\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127501045761
    m_Localized: "\uD6C4\uB808\uC544\uB294 \uB77C\uC778 \uD074\uB9AC\uC5B4\uC5D0
      \uD2B9\uD654\uB41C \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uAE34
      \uC0AC\uAC70\uB9AC\uB97C \uAC00\uC9C0\uACE0 \uC788\uC9C0\uB9CC HP\uAC00 \uB0AE\uAE30\uC5D0,
      \uD6C4\uBC29\uC5D0 \uBC30\uCE58\uD558\uB294 \uAC83\uC744 \uCD94\uCC9C\uB4DC\uB9BD\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uD1B5\uD574 \uB354\uC6B1 \uB113\uC740
      \uBC94\uC704\uC758 \uACF5\uACA9\uC744 \uAC00\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127501045762
    m_Localized: "\uB178\uC5D8\uC740 \uCCB4\uB825\uC774 \uB9CE\uACE0, \uB370\uBBF8\uC9C0\uAC00
      \uB192\uC740 \uB300\uC2E0 \uB290\uB9B0 \uACF5\uACA9\uC18D\uB3C4\uB97C \uAC00\uC9C4
      \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC804\uBC29\uC5D0
      \uBC30\uCE58\uD558\uC5EC \uC6D0\uAC70\uB9AC \uC720\uB2DB\uC758 \uBC14\uB9AC\uAC8C\uC774\uD2B8
      \uC5ED\uD560\uC744 \uC2DC\uD0A4\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uD1B5\uD574 \uBAB9\uBAB0\uC774, \uC2A4\uD134
      \uB4F1 \uBAAC\uC2A4\uD130\uC758 \uD589\uB3D9\uC744 \uC81C\uC57D\uD558\uB294
      \uB2A5\uB825\uC744 \uAC00\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434368
    m_Localized: "\uAD6C\uB77C\uB294 \uC900\uC218\uD55C \uBC94\uC704\uC640 \uB370\uBBF8\uC9C0,
      HP\uB97C \uAC00\uC9C4 \uBC38\uB7F0\uC2A4 \uD615 \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4.
      \uCD5C\uB300\uD55C \uB9CE\uC774 \uC6C0\uC9C1\uC774\uBA70 \uB2E4\uB978 \uB77C\uC778\uC744
      \uB3D5\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
      \uD1B5\uD574 \uB354\uC6B1 \uB113\uC740 \uBC94\uC704\uC640 \uC911\uCCA9 \uB370\uBBF8\uC9C0\uB97C
      \uAC00\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434369
    m_Localized: "\uCF54\uB85C\uB124\uB294 \uB6F0\uC5B4\uB09C \uC9D1\uC911 \uACF5\uACA9
      \uB2A5\uB825\uC744 \uC9C0\uB2CC \uB300\uC2E0 \uC881\uC740 \uC0AC\uAC70\uB9AC\uB97C
      \uAC00\uC9C4 \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uBAAC\uC2A4\uD130\uC5D0
      \uD070 \uD53C\uD574\uB97C \uC904 \uC218 \uC788\uB294 \uD55C\uD3B8, \uC0AC\uAC70\uB9AC\uAC00
      \uAC00\uAE5D\uAE30\uC5D0 \uBAAC\uC2A4\uD130 \uD328\uD134\uC5D0 \uC9C1\uACA9\uB2F9\uD560
      \uC704\uD5D8\uB3C4 \uD568\uAED8 \uAC00\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uD1B5\uD574 \uB370\uBBF8\uC9C0\uB97C
      \uB354\uC6B1 \uB354 \uAC15\uD654\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434370
    m_Localized: "\uC640\uD0C0\uBA54\uB294 \uD22C\uC0AC\uCCB4 \uC720\uB2DB \uC9C0\uC6D0\uC5D0
      \uD2B9\uD654\uB41C \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uB418\uB3C4\uB85D
      \uC720\uB2DB\uC774 \uB9CE\uC740 \uB77C\uC778\uC5D0 \uD568\uAED8 \uBC30\uCE58\uD558\uB294
      \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
      \uD1B5\uD574 \uC6D0\uAC70\uB9AC \uC720\uB2DB\uB4E4\uC758 \uBC14\uB9AC\uAC8C\uC774\uD2B8\uB97C
      \uC9C0\uC6D0\uD574 \uC904 \uC218 \uC788\uC73C\uBA70, \uC801\uC744 \uB290\uB9AC\uAC8C
      \uB9CC\uB4E4\uC5B4 \uC720\uB2DB\uC5D0\uAC8C \uC811\uADFC\uD558\uB294 \uAC83\uC744
      \uB2A6\uCD9C \uC218 \uC788\uC2B5\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 127509434371
    m_Localized: "\uC2A4\uBC14\uB8E8\uB294 \uAE34 \uC0AC\uAC70\uB9AC\uC640 \uB6F0\uC5B4\uB09C
      \uBAAC\uC2A4\uD130 \uACAC\uC7AC \uB2A5\uB825\uC744 \uAC00\uC9C4 \uBC94\uC704\uACF5\uACA9
      \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC2A4\uBC14\uB8E8\uC758 \uD328\uD134\uC744
      \uC801\uC808\uD788 \uD65C\uC6A9\uD558\uBA74, \uAC00\uD558\uB294 \uB370\uBBF8\uC9C0\uAC00
      \uC801\uC5B4\uC9C0\uB294 \uB300\uC2E0 \uBAAC\uC2A4\uD130\uB97C \uD06C\uAC8C
      \uBC00\uCCD0\uB0B4\uC5B4 \uC804\uC9C4\uB825\uC744 \uB2A6\uCD9C \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uD1B5\uD574 \uAC00\uD558\uB294 \uD798\uC744
      \uB354\uC6B1 \uB298\uB9B4 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434372
    m_Localized: "\uC544\uBA5C\uB9AC\uC544\uB294 \uBC38\uB7F0\uC2A4\uD615 \uD22C\uC0AC\uCCB4
      \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC900\uC218\uD55C \uB77C\uC778 \uD074\uB9AC\uC5B4
      \uB2A5\uB825\uC744 \uAC00\uC9C0\uACE0 \uC788\uC74C\uACFC \uB3D9\uC2DC\uC5D0,
      \uB2E8\uC77C \uBAAC\uC2A4\uD130\uC5D0\uAC8C \uD2B9\uD788 \uB354 \uAC15\uB825\uD55C
      \uD654\uB825\uC744 \uAC00\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4. \uC0AC\uB9DD\uD55C
      \uC720\uB2DB\uC774 \uC788\uB2E4\uBA74, \uD574\uB2F9 \uC0AC\uB9DD \uC720\uB2DB\uC774
      \uB354 \uBE68\uB9AC \uBD80\uD65C\uD560 \uC218 \uC788\uB3C4\uB85D \uB3D5\uAE30\uB3C4
      \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434373
    m_Localized: "\uCE7C\uB9AC\uC624\uD398\uB294 \uB113\uC740 \uACF5\uACA9\uBC94\uC704\uC640
      \uC2DC\uAC04\uC774 \uC9C0\uB0A0\uC218\uB85D \uC810\uCC28 \uAC15\uD574\uC9C0\uB294
      \uB2A5\uB825\uC744 \uAC00\uC9C4 \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4.
      \uAE30\uBCF8 \uD328\uD134\uC740 \uC18D\uB3C4\uB294 \uB290\uB9AC\uC9C0\uB9CC
      \uC138\uB85C \uBC94\uC704\uAC00 \uB113\uAE30\uC5D0, \uC790\uC2E0\uC758 \uB77C\uC778
      \uBFD0 \uC544\uB2C8\uB77C \uB2E4\uB978 \uB77C\uC778\uAE4C\uC9C0\uB3C4 \uC27D\uAC8C
      \uCEE4\uBC84\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434374
    m_Localized: "\uCE74\uB098\uD0C0\uB294 \uCC9C\uCC9C\uD788 \uC2A4\uD0DD\uC744
      \uC313\uC544 \uAC15\uB825\uD55C \uD55C\uBC29\uC744 \uB0A0\uB9B4 \uC218 \uC788\uB294
      \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uCE74\uB098\uD0C0\uAC00
      \uC8FD\uC73C\uBA74 \uBAA8\uB4E0 \uC2A4\uD0DD\uC774 \uC0AC\uB77C\uC9C0\uAE30
      \uB54C\uBB38\uC5D0, \uC0DD\uC874\uC5D0 \uC720\uC758\uD558\uBA70 \uBCF4\uC2A4
      \uC2A4\uD14C\uC774\uC9C0\uAE4C\uC9C0 \uC2A4\uD0DD\uC744 \uC720\uC9C0\uD558\uB294
      \uAC83\uC744 \uBAA9\uD45C\uB85C \uD558\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434375
    m_Localized: "\uB8E8\uB098\uB294 \uC720\uB2DB\uC744 \uD68C\uBCF5\uD558\uACE0
      \uBC84\uD504\uB97C \uC8FC\uB294 \uB2A5\uB825\uC5D0 \uB354\uD574, \uC2A4\uD134\uC5D0
      \uD2B9\uD654\uB41C \uC11C\uD3EC\uD130 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uB2E4\uC591\uD55C
      \uC885\uB958\uC758 \uB514\uC800\uD2B8\uB97C \uC18C\uD658\uD558\uC5EC \uC720\uB2DB\uB4E4\uC5D0\uAC8C
      \uD68C\uBCF5\uACFC \uD568\uAED8 \uB2E4\uC591\uD55C \uBC84\uD504\uB97C \uC904
      \uC218\uB3C4 \uC788\uC73C\uBA70, \uC77C\uC815 \uC2DC\uAC04\uB9C8\uB2E4 \uB8E8\uB098\uC774\uD2B8\uB97C
      \uB0B4\uBCF4\uB0B4 \uBAAC\uC2A4\uD130\uB97C \uAE30\uC808\uC2DC\uCF1C \uD328\uD134\uC744
      \uB04A\uC744 \uC218\uB3C4 \uC788\uC2B5\uB2C8\uB2E4. \uC0C1\uD669\uC5D0 \uB9DE\uCD94\uC5B4
      \uB9C8\uBC95\uCE94\uB514\uB97C \uC5B4\uB5A4 \uC720\uB2DB\uC5D0\uAC8C \uC8FC\uB290\uB0D0\uC5D0
      \uB530\uB77C, \uC720\uB2DB \uC804\uCCB4\uC758 \uB370\uBBF8\uC9C0\uB97C \uAC15\uD654\uD558\uAC70\uB098,
      \uAC15\uB825\uD55C \uB77C\uC778\uD074\uB9AC\uC5B4\uC640 \uD568\uAED8 \uB8E8\uB098
      \uBCF8\uC778\uC758 \uC2A4\uD134 \uB2A5\uB825\uC744 \uB354\uC6B1 \uAC15\uD654\uC2DC\uD0AC\uC218\uB3C4
      \uC788\uC2B5\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 127509434376
    m_Localized: "\uD6C4\uBD80\uD0A4\uB294 \uD3C9\uC18C \uB2E4\uB978 \uBC94\uC704\uACF5\uACA9
      \uC720\uB2DB\uC5D0 \uBE44\uD574 \uC57D\uD55C \uB300\uC2E0, \uBCC0\uC2E0\uC744
      \uD1B5\uD574 \uB9C9\uAC15\uD55C \uB370\uBBF8\uC9C0 \uD3EC\uD150\uC15C\uC744
      \uBF50\uB0BC \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uAC8C\uC774\uC9C0\uB97C \uCD5C\uB300\uD55C
      \uC798 \uAD00\uB9AC\uD558\uC5EC \uCFE0\uB85C\uCE74\uBBF8 \uD6C4\uBD80\uD0A4
      \uC0C1\uD0DC\uB97C \uC624\uB798 \uC720\uC9C0\uD558\uB294 \uAC83\uC774 \uAD00\uAC74\uC774\uBA70,
      \uC774\uB97C \uC704\uD574 \uAC8C\uC774\uC9C0\uB97C \uB108\uBB34 \uB0A8\uC6A9\uD558\uC9C0
      \uC54A\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434377
    m_Localized: "\uD1A0\uC640\uB294 \uB2E4\uB978 \uB77C\uC778\uC5D0 \uC788\uB294
      \uBAAC\uC2A4\uD130\uB97C \uB04C\uC5B4\uB2F9\uAE30\uACE0, \uC6D0\uAC70\uB9AC\uC5D0\uC11C
      \uAD00\uD1B5 \uB808\uC774\uC800\uB97C \uBC1C\uC0AC\uD558\uB294 \uB4F1 \uB77C\uC778\uD074\uB9AC\uC5B4\uC5D0
      \uD2B9\uD654\uB41C \uC720\uB2DB\uC785\uB2C8\uB2E4. \uB300\uC2E0 \uACF5\uACA9\uC18D\uB3C4\uAC00
      \uB290\uB9AC\uACE0, \uD654\uB825\uC774 \uB2E4\uC18C \uBD80\uC871\uD558\uC5EC
      \uBCF4\uC2A4 \uBAAC\uC2A4\uD130\uB098 \uCCB4\uB825\uC774 \uB9CE\uC740 \uBAAC\uC2A4\uD130\uB97C
      \uC0C1\uB300\uD560\uB54C\uB294 \uD654\uB825\uC744 \uBCF4\uC870\uD574 \uC904
      \uC720\uB2DB\uACFC \uAC19\uC774 \uC0AC\uC6A9\uD558\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434378
    m_Localized: "\uBB34\uBA54\uC774\uB294 \uACF5\uACA9\uC18D\uB3C4\uB97C \uB298\uB824\uC11C,
      \uB9CE\uC740 \uD22C\uC0AC\uCCB4\uB97C \uBC1C\uC0AC\uD558\uB294 \uAC83\uC774
      \uAE43\uD138 \uD3ED\uBC1C\uC744 \uB9CE\uC774 \uC77C\uC73C\uD0AC \uC218 \uC788\uC5B4
      \uC720\uB9AC\uD569\uB2C8\uB2E4. \uC5C5\uADF8\uB808\uC774\uB4DC\uAC00 \uBAA8\uB450
      \uB05D\uB09C \uBB34\uBA54\uC774\uB294 \uB77C\uC778\uD074\uB9AC\uC5B4 \uB2A5\uB825\uC744
      \uD06C\uAC8C \uAC15\uD654\uC2DC\uD0AC \uC218 \uC788\uC2B5\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 127509434379
    m_Localized: "\uB77C\uBBF8\uB294 \uB113\uC740 \uACF5\uACA9 \uBC94\uC704\uC640
      \uBB34\uC801 \uC2A4\uD0AC\uC744 \uAC16\uCD94\uACE0 \uC788\uC5B4, \uC5B4\uB5A4
      \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uC548\uC815\uC801\uC778 \uD50C\uB808\uC774\uAC00
      \uAC00\uB2A5\uD55C \uC720\uB2DB\uC785\uB2C8\uB2E4. \uD55C \uBC88\uC5D0 \uD070
      \uB370\uBBF8\uC9C0\uB97C \uC8FC\uC9C4 \uC54A\uC9C0\uB9CC, \uC9C0\uC18D\uC801\uC778
      \uD53C\uD574\uB97C \uD1B5\uD574 \uAC15\uB825\uD55C \uC131\uB2A5\uC744 \uBC1C\uD718\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 127509434380
    m_Localized: "\uC2A4\uC774\uC138\uC774\uB294 \uC900\uC218\uD55C \uC0AC\uAC70\uB9AC\uC640
      \uBC94\uC704 \uACF5\uACA9\uC744 \uAC00\uC9C0\uACE0 \uC788\uB294 \uBC38\uB7F0\uC2A4\uD615
      \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC561\uD2F0\uBE0C
      \uD328\uD134\uC744 \uD1B5\uD574 \uC2A4\uD0DD\uC744 \uC313\uACE0, \uD544\uB4DC\uB97C
      \uBAA8\uB450 \uC815\uB9AC\uD560 \uC218 \uC788\uB294 \uAC15\uB825\uD55C \uACF5\uACA9\uC744
      \uAC00\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 6626900816924672
    m_Localized: "\uD30C\uC6B0\uB098\uB294 \uB113\uC740 \uBC94\uC704\uC758 \uAD11\uC5ED
      \uD68C\uBCF5\uACFC \uBC84\uD504\uB97C \uAC00\uC9C4 \uC11C\uD3EC\uD130 \uC720\uB2DB\uC73C\uB85C,
      \uD30C\uC885\uC744 \uD1B5\uD574 \uC720\uB2DB\uC758 \uD2B9\uC131\uC5D0 \uB530\uB77C
      \uB2E4\uC591\uD55C \uBC84\uD504\uB97C \uC81C\uACF5\uD574\uC904 \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uB9C8\uCE5C \uD30C\uC6B0\uB098\uB294
      \uAE09\uC18D\uC131\uC7A5\uC744 \uD1B5\uD574 \uBAAC\uC2A4\uD130\uC758 \uC9C4\uCD9C\uC744
      \uB9C9\uC544\uB0B4\uB294 \uBCBD\uC744 \uC0DD\uC131\uD560 \uC218 \uC788\uC5B4,
      \uC6D0\uAC70\uB9AC\uC5D0\uC11C \uBAAC\uC2A4\uD130\uB97C \uACF5\uACA9\uD560
      \uC218 \uC788\uB294 \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uB4E4\uACFC \uC870\uD569\uC774
      \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 6626900858867712
    m_Localized: "\uC62C\uB9AC\uB294 \uAE34 \uC0AC\uAC70\uB9AC\uC640 \uD761\uD608
      \uB2A5\uB825, \uC18C\uD658\uC218\uB4E4\uC744 \uD1B5\uD55C \uD0F1\uD0B9 \uB4F1
      \uC0DD\uC874\uC5D0 \uD2B9\uD654\uB41C \uBC94\uC704\uACF5\uACA9 \uC720\uB2DB\uC785\uB2C8\uB2E4.
      \uCD5C\uB300\uD55C \uC624\uB798 \uC0DD\uC874\uD558\uBA74\uC11C, \uBE44\uC11D\uC758
      \uAC1C\uC218\uB97C \uCD5C\uB300\uB85C \uC720\uC9C0\uD558\uB294 \uAC83\uC774
      \uC88B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8131748989210624
    m_Localized: "\uCF54\uBCF4\uB294 \uBAAC\uC2A4\uD130\uC758 \uC9C4\uCD9C\uC744
      \uBC29\uD574\uD558\uB294 \uB2E4\uC591\uD55C cc\uAE30\uB97C \uBCF4\uC720\uD558\uACE0
      \uC788\uB294 \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC73C\uB85C, \uC870\uC791 \uC5EC\uD558\uC5D0
      \uB530\uB77C \uB113\uC740 \uBC94\uC704\uB97C \uCEE4\uBC84\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uD655\uC815 \uC2A4\uD134 \uAE30\uB2A5\uC73C\uB85C \uC778\uD574 \uBCF4\uC2A4
      \uACAC\uC81C\uB098 \uD2B9\uC218 \uBAAC\uC2A4\uD130 \uACAC\uC81C\uC5D0\uB3C4
      \uC88B\uC740 \uC720\uB2DB\uC785\uB2C8\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 28207254136655872
    m_Localized: "\uC18C\uB77C\uB294 \uBAA8\uB4E0 \uC720\uB2DB\uC744 \uCF00\uC5B4\uD558\uB294
      \uB2A5\uB825\uC740 \uB2E4\uB978 \uC720\uB2DB\uB4E4\uC5D0 \uBE44\uD574 \uBD80\uC871\uD558\uC9C0\uB9CC,
      \uB2E8\uC77C \uC720\uB2DB\uC758 \uC131\uB2A5\uC744 \uD06C\uAC8C \uBCF4\uC870\uD574\uC904
      \uC218 \uC788\uB294 \uC11C\uD3EC\uD130 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC561\uD2F0\uBE0C
      \uD328\uD134\uC744 \uD1B5\uD574 \uBAA8\uB4E0 \uC720\uB2DB\uC758 \uC131\uB2A5\uC744
      \uAC15\uD654\uC2DC\uD0AC\uC218\uB3C4 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 28207254186987520
    m_Localized: "\uBBF8\uCF54\uB294 \uC640\uD0C0\uBA54\uC640 \uAC19\uC774 \uC11C\uD3EC\uD130
      \uB2A5\uB825\uC744 \uACB8\uBE44\uD55C \uD22C\uC0AC\uCCB4 \uC720\uB2DB\uC785\uB2C8\uB2E4.
      \uC9C0\uC18D\uC801\uC73C\uB85C \uC6B4\uC138\uC885\uC774\uB97C \uC120\uD0DD\uD558\uC5EC
      \uC544\uAD70 \uC720\uB2DB\uC744 \uB3D5\uAC70\uB098 \uBAAC\uC2A4\uD130\uC5D0\uAC8C
      \uD53C\uD574\uB97C \uC785\uD790 \uC218 \uC788\uC73C\uBA70, '\uBC9A\uAF43\uAE38'\uC744
      \uD1B5\uD574 \uBAAC\uC2A4\uD130\uC758 \uC9C4\uCD9C\uC744 \uBC29\uD574\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
