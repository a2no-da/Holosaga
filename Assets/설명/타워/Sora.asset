  sul: "2017\uB144 9\uC6D4 7\uC77C\uBD80\uD130 \uD65C\uB3D9\uC744 \uC2DC\uC791\uD55C
    \uD640\uB85C\uB77C\uC774\uBE0C \uD504\uB85C\uB355\uC158 \uCD5C\uCD08\uC758 \uBC84\uCE04\uC5BC
    \uC544\uC774\uB3CC. \uB178\uB798\uC640 \uD638\uB7EC \uAC8C\uC784\uC744 \uC88B\uC544\uD558\uACE0,
    \uD65C\uB3D9 \uCD08\uAE30\uBD80\uD130 \"\uC694\uCF54\uD558\uB9C8 \uC544\uB808\uB098\uC5D0\uC11C
    \uB77C\uC774\uBE0C\uB97C \uD558\uB294 \uAC83\"\uC744 \uAFC8\uAFB8\uACE0 \uC788\uB2E4.\n\n\uC18C\uB77C\uB294
    \uBAA8\uB4E0 \uC720\uB2DB\uC744 \uCF00\uC5B4\uD558\uB294 \uB2A5\uB825\uC740 \uB2E4\uB978
    \uC720\uB2DB\uB4E4\uC5D0 \uBE44\uD574 \uBD80\uC871\uD558\uC9C0\uB9CC, \uB2E8\uC77C
    \uC720\uB2DB\uC758 \uC131\uB2A5\uC744 \uD06C\uAC8C \uBCF4\uC870\uD574\uC904 \uC218
    \uC788\uB294 \uC11C\uD3EC\uD130 \uC720\uB2DB\uC785\uB2C8\uB2E4. \uC561\uD2F0\uBE0C
    \uD328\uD134\uC744 \uD1B5\uD574 \uBAA8\uB4E0 \uC720\uB2DB\uC758 \uC131\uB2A5\uC744
    \uAC15\uD654\uC2DC\uD0AC\uC218\uB3C4 \uC788\uC2B5\uB2C8\uB2E4."
